---
const services = [
  {
    title: "Custom Kitchens",
    text: "Modern fitted kitchens designed around your space, storage needs, appliances, and finish choices."
  },
  {
    title: "Built-In Cupboards",
    text: "Bedroom cupboards, wardrobes, linen cupboards, and smart storage units made to fit properly."
  },
  {
    title: "TV Units",
    text: "Clean floating TV units, feature walls, display shelving, and practical cable-friendly storage."
  },
  {
    title: "Vanities & Storage",
    text: "Bathroom vanities, laundry cupboards, garage storage, office units, and custom home storage."
  }
];

const steps = [
  "Measure the space",
  "Plan the layout",
  "Choose finishes",
  "Build and install"
];

const finishes = [
  "White melamine",
  "Woodgrain melamine",
  "MDF painted finishes",
  "Modern handles",
  "Soft-close hardware",
  "Quartz-ready designs"
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WhichwoodFitters | Custom Carpentry & Built-In Cupboards</title>
    <meta
      name="description"
      content="WhichwoodFitters builds custom kitchens, built-in cupboards, wardrobes, TV units, vanities, and storage solutions in South Africa."
    />
    <style>
      :root {
        --bg: #0f0c08;
        --bg-soft: #18130d;
        --card: rgba(255, 255, 255, 0.08);
        --card-border: rgba(255, 255, 255, 0.14);
        --text: #fff7ed;
        --muted: #d8c7b0;
        --gold: #d8a85d;
        --wood: #8b5a2b;
        --cream: #fff2dc;
        --dark: #080604;
        --green: #8fa874;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(216, 168, 93, 0.18), transparent 36rem),
          radial-gradient(circle at bottom right, rgba(139, 90, 43, 0.22), transparent 34rem),
          var(--bg);
        color: var(--text);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        overflow: hidden;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 20;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem clamp(1rem, 4vw, 4rem);
        backdrop-filter: blur(18px);
        background: rgba(15, 12, 8, 0.78);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-weight: 900;
        letter-spacing: -0.04em;
        font-size: clamp(1.1rem, 2vw, 1.5rem);
      }

      .brand-mark {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.18), transparent),
          linear-gradient(135deg, var(--gold), var(--wood));
        display: grid;
        place-items: center;
        color: var(--dark);
        font-weight: 1000;
        box-shadow: 0 16px 40px rgba(216, 168, 93, 0.22);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 1.1rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .nav-links a:hover {
        color: var(--cream);
      }

      .nav-cta,
      .btn-primary,
      .btn-secondary {
        border-radius: 999px;
        padding: 0.85rem 1.15rem;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease,
          border-color 0.2s ease;
      }

      .nav-cta,
      .btn-primary {
        background: linear-gradient(135deg, var(--gold), #f2d18e);
        color: #171007;
        box-shadow: 0 18px 45px rgba(216, 168, 93, 0.22);
      }

      .btn-secondary {
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: var(--cream);
        background: rgba(255, 255, 255, 0.06);
      }

      .nav-cta:hover,
      .btn-primary:hover,
      .btn-secondary:hover {
        transform: translateY(-2px);
      }

      .hero {
        min-height: 88vh;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        align-items: center;
        gap: clamp(2rem, 5vw, 5rem);
        padding: clamp(4rem, 8vw, 7rem) clamp(1rem, 4vw, 4rem);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.5rem 0.8rem;
        border: 1px solid rgba(216, 168, 93, 0.35);
        border-radius: 999px;
        background: rgba(216, 168, 93, 0.08);
        color: #f6d59b;
        font-size: 0.88rem;
        font-weight: 800;
        margin-bottom: 1.2rem;
      }

      .hero h1 {
        margin: 0;
        max-width: 900px;
        font-size: clamp(3rem, 8vw, 6.8rem);
        line-height: 0.9;
        letter-spacing: -0.075em;
      }

      .hero h1 span {
        color: var(--gold);
      }

      .hero p {
        max-width: 680px;
        margin: 1.4rem 0 0;
        color: var(--muted);
        font-size: clamp(1.05rem, 2vw, 1.35rem);
        line-height: 1.7;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
        margin-top: 2rem;
      }

      .trust-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.8rem;
        margin-top: 2.2rem;
        max-width: 720px;
      }

      .trust-card {
        border: 1px solid var(--card-border);
        background: rgba(255, 255, 255, 0.06);
        border-radius: 22px;
        padding: 1rem;
      }

      .trust-card strong {
        display: block;
        color: var(--cream);
        font-size: 1.4rem;
      }

      .trust-card span {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .hero-visual {
        position: relative;
        min-height: 560px;
        border-radius: 38px;
        padding: 1rem;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.14), transparent),
          rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.14);
        box-shadow: 0 40px 90px rgba(0, 0, 0, 0.32);
      }

      .wood-panel {
        height: 100%;
        min-height: 530px;
        border-radius: 30px;
        background:
          linear-gradient(90deg, rgba(255, 255, 255, 0.08), transparent 30%),
          repeating-linear-gradient(
            90deg,
            #7a4d24 0,
            #7a4d24 18px,
            #8b5a2b 18px,
            #8b5a2b 38px,
            #a46f35 38px,
            #a46f35 58px
          );
        position: relative;
        overflow: hidden;
      }

      .wood-panel::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.2), transparent 18rem),
          linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.36));
      }

      .floating-box {
        position: absolute;
        left: 8%;
        right: 8%;
        bottom: 8%;
        border-radius: 26px;
        padding: 1.2rem;
        background: rgba(8, 6, 4, 0.78);
        border: 1px solid rgba(255, 255, 255, 0.14);
        backdrop-filter: blur(16px);
      }

      .floating-box h3 {
        margin: 0;
        font-size: 1.35rem;
      }

      .floating-box p {
        margin: 0.5rem 0 0;
        color: var(--muted);
        line-height: 1.5;
      }

      .section {
        padding: clamp(4rem, 8vw, 7rem) clamp(1rem, 4vw, 4rem);
      }

      .section-head {
        max-width: 780px;
        margin-bottom: 2rem;
      }

      .section-head h2 {
        margin: 0;
        font-size: clamp(2.2rem, 5vw, 4.2rem);
        line-height: 1;
        letter-spacing: -0.06em;
      }

      .section-head p {
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.7;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      }

      .service-card,
      .process-card,
      .quote-card {
        border: 1px solid var(--card-border);
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.035)),
          var(--card);
        border-radius: 28px;
        padding: 1.4rem;
        box-shadow: 0 26px 70px rgba(0, 0, 0, 0.18);
      }

      .service-card h3,
      .process-card h3 {
        margin: 0;
        font-size: 1.25rem;
      }

      .service-card p,
      .process-card p {
        color: var(--muted);
        line-height: 1.6;
      }

      .number {
        width: 42px;
        height: 42px;
        border-radius: 15px;
        display: grid;
        place-items: center;
        background: rgba(216, 168, 93, 0.16);
        color: #f8d99d;
        font-weight: 900;
        margin-bottom: 1rem;
      }

      .split {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 1rem;
        align-items: stretch;
      }

      .showcase {
        min-height: 520px;
        border-radius: 34px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background:
          linear-gradient(135deg, rgba(216, 168, 93, 0.24), transparent),
          linear-gradient(160deg, #25190f, #0f0c08);
        padding: 1.2rem;
        display: grid;
        align-content: end;
        overflow: hidden;
        position: relative;
      }

      .showcase::before {
        content: "";
        position: absolute;
        inset: 1.2rem;
        border-radius: 26px;
        background:
          linear-gradient(90deg, transparent 0 8%, rgba(255, 255, 255, 0.08) 8% 9%, transparent 9% 100%),
          linear-gradient(0deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 100%);
        background-size: 100% 100%, 100% 78px;
        opacity: 0.65;
      }

      .showcase-content {
        position: relative;
        border-radius: 24px;
        background: rgba(8, 6, 4, 0.76);
        border: 1px solid rgba(255, 255, 255, 0.12);
        padding: 1.3rem;
      }

      .showcase-content h3 {
        margin: 0;
        font-size: 1.5rem;
      }

      .showcase-content p {
        color: var(--muted);
        line-height: 1.6;
      }

      .finish-list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.8rem;
      }

      .finish-item {
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.055);
        border-radius: 20px;
        padding: 1rem;
        color: var(--cream);
        font-weight: 750;
      }

      .quote {
        padding-top: 0;
      }

      .quote-card {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        gap: 2rem;
        background:
          linear-gradient(135deg, rgba(216, 168, 93, 0.22), rgba(255, 255, 255, 0.05)),
          rgba(255, 255, 255, 0.06);
      }

      .quote-card h2 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3.4rem);
        line-height: 1;
        letter-spacing: -0.05em;
      }

      .quote-card p {
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.65;
      }

      .footer {
        padding: 2rem clamp(1rem, 4vw, 4rem);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--muted);
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      @media (max-width: 980px) {
        .hero,
        .split {
          grid-template-columns: 1fr;
        }

        .hero-visual {
          min-height: 460px;
        }

        .wood-panel {
          min-height: 430px;
        }

        .grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .quote-card {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 680px) {
        .nav-links {
          display: none;
        }

        .hero {
          padding-top: 3rem;
        }

        .trust-row,
        .grid,
        .finish-list {
          grid-template-columns: 1fr;
        }

        .hero-actions {
          flex-direction: column;
        }

        .btn-primary,
        .btn-secondary,
        .nav-cta {
          width: 100%;
        }

        .hero h1 {
          font-size: clamp(2.7rem, 16vw, 4.5rem);
        }
      }
    </style>
  </head>

  <body>
    <main class="page">
      <nav class="nav">
        <a class="brand" href="/">
          <span class="brand-mark">W</span>
          <span>WhichwoodFitters</span>
        </a>

        <div class="nav-links">
          <a href="#services">Services</a>
          <a href="#process">Process</a>
          <a href="#finishes">Finishes</a>
        </div>

        <a class="nav-cta" href="#quote">Get a Quote</a>
      </nav>

      <section class="hero">
        <div>
          <div class="eyebrow">Custom carpentry • Built to fit</div>
          <h1>Turn empty space into <span>beautiful storage.</span></h1>
          <p>
            WhichwoodFitters builds custom kitchens, built-in cupboards,
            wardrobes, TV units, vanities, and practical storage solutions with
            clean installation and strong workmanship.
          </p>

          <div class="hero-actions">
            <a class="btn-primary" href="#quote">Request a Quote</a>
            <a class="btn-secondary" href="#services">View Services</a>
          </div>

          <div class="trust-row">
            <div class="trust-card">
              <strong>Made</strong>
              <span>to your exact space</span>
            </div>
            <div class="trust-card">
              <strong>Clean</strong>
              <span>modern finishes</span>
            </div>
            <div class="trust-card">
              <strong>Strong</strong>
              <span>practical builds</span>
            </div>
          </div>
        </div>

        <div class="hero-visual" aria-label="Wood finish visual">
          <div class="wood-panel"></div>
          <div class="floating-box">
            <h3>Measured. Planned. Fitted properly.</h3>
            <p>
              From small storage upgrades to full kitchens, the work starts with
              accurate measurements and ends with a clean finished result.
            </p>
          </div>
        </div>
      </section>

      <section class="section" id="services">
        <div class="section-head">
          <h2>Built for real homes, not showroom guesses.</h2>
          <p>
            Every cupboard, unit, and kitchen should fit the room, the walls,
            the client’s storage needs, and the budget. That is where custom
            carpentry wins.
          </p>
        </div>

        <div class="grid">
          {services.map((service) => (
            <article class="service-card">
              <h3>{service.title}</h3>
              <p>{service.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="process">
        <div class="section-head">
          <h2>A simple process that keeps the job clear.</h2>
          <p>
            Clear measurements, clear planning, clear finishes, and clean
            fitting. That is how a project stays under control.
          </p>
        </div>

        <div class="grid">
          {steps.map((step, index) => (
            <article class="process-card">
              <div class="number">{index + 1}</div>
              <h3>{step}</h3>
              <p>
                We keep this stage practical so the final build fits the space
                and the client knows what is being made.
              </p>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="finishes">
        <div class="split">
          <div class="showcase">
            <div class="showcase-content">
              <h3>Premium look. Practical materials.</h3>
              <p>
                Choose finishes that match the room and the budget, from clean
                white melamine to warm woodgrain and painted MDF looks.
              </p>
            </div>
          </div>

          <div>
            <div class="section-head">
              <h2>Popular finish options.</h2>
              <p>
                The right finish makes the difference between a normal cupboard
                and a fitted unit that feels like part of the home.
              </p>
            </div>

            <div class="finish-list">
              {finishes.map((finish) => (
                <div class="finish-item">{finish}</div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="section quote" id="quote">
        <div class="quote-card">
          <div>
            <h2>Ready to price your space?</h2>
            <p>
              Send photos, rough measurements, and what you want built. We can
              help turn the idea into a proper custom-fitted solution.
            </p>
          </div>
          <a class="btn-primary" href="mailto:ruhantait@yahoo.com">
            Email for a Quote
          </a>
        </div>
      </section>

      <footer class="footer">
        <span>© 2026 WhichwoodFitters. All rights reserved.</span>
        <span>Custom kitchens • cupboards • wardrobes • TV units</span>
      </footer>
    </main>
  </body>
</html>
