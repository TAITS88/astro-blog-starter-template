---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>WhichwoodFitters | Premium Custom Kitchens, Cupboards & Fitted Storage</title>

    <meta
      name="description"
      content="WhichwoodFitters designs and installs premium custom kitchens, built-in cupboards, wardrobes, TV units, vanities and fitted storage in South Africa."
    />

    <meta property="og:title" content="WhichwoodFitters | Custom Kitchens & Built-In Cupboards" />
    <meta
      property="og:description"
      content="Premium custom carpentry and fitted storage made to fit your exact space."
    />
    <meta property="og:image" content="/images/hero-main.jpg" />
    <meta property="og:type" content="website" />

    <style>
      :root {
        --ink: #14110d;
        --ink-soft: #211a13;
        --paper: #f6f0e6;
        --paper-2: #eee2d2;
        --cream: #fffaf2;
        --muted: #7b6c5c;
        --muted-2: #a3927c;
        --wood: #a66b35;
        --wood-2: #c18a4a;
        --bronze: #d9a85f;
        --olive: #5d654c;
        --white-soft: rgba(255, 250, 242, 0.82);
        --line: rgba(20, 17, 13, 0.13);
        --line-strong: rgba(20, 17, 13, 0.28);
        --dark-line: rgba(255, 250, 242, 0.14);
        --shadow: 0 36px 100px rgba(33, 23, 12, 0.18);
        --shadow-dark: 0 44px 120px rgba(0, 0, 0, 0.28);
        --radius-xl: 48px;
        --radius-lg: 32px;
        --radius-md: 22px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--ink);
        background:
          radial-gradient(circle at 10% 0%, rgba(217, 168, 95, 0.20), transparent 28rem),
          radial-gradient(circle at 90% 8%, rgba(93, 101, 76, 0.16), transparent 34rem),
          linear-gradient(135deg, var(--paper), var(--paper-2));
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        opacity: 0.12;
        background-image:
          linear-gradient(rgba(20, 17, 13, 0.11) 1px, transparent 1px),
          linear-gradient(90deg, rgba(20, 17, 13, 0.11) 1px, transparent 1px);
        background-size: 92px 92px;
        mask-image: linear-gradient(to bottom, black, transparent 78%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input,
      select,
      textarea {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      img {
        max-width: 100%;
      }

      h1,
      h2,
      h3 {
        font-family: Georgia, "Times New Roman", serif;
        font-weight: 500;
      }

      .site {
        position: relative;
        z-index: 1;
      }

      .nav {
        position: fixed;
        inset: 0 0 auto;
        z-index: 80;
        display: grid;
        grid-template-columns: auto auto minmax(0, 1fr) auto;
        align-items: center;
        gap: 1rem;
        padding: 0.9rem clamp(1rem, 4vw, 4.8rem);
        background: rgba(246, 240, 230, 0.82);
        border-bottom: 1px solid rgba(20, 17, 13, 0.08);
        backdrop-filter: blur(22px);
      }

      .nav-links {
        justify-self: center;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.35rem;
        border: 1px solid rgba(20, 17, 13, 0.10);
        border-radius: 999px;
        background: rgba(255, 250, 242, 0.52);
        box-shadow: 0 12px 32px rgba(33, 23, 12, 0.08);
      }

      .nav-links a {
        min-height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.62rem 0.9rem;
        border-radius: 999px;
        color: var(--ink);
        font-size: 0.82rem;
        font-weight: 950;
        transition:
          transform 0.2s ease,
          background 0.2s ease,
          color 0.2s ease;
      }

      .nav-links a:hover {
        color: var(--paper);
        background: var(--ink);
        transform: translateY(-1px);
      }

      .nav-links a.nav-quote-link {
        color: #22160d;
        background: linear-gradient(135deg, #f2cf89, #c88d3f);
      }

      .section,
      .quote-section {
        scroll-margin-top: 96px;
      }

      .menu-button,
      .nav-email {
        width: fit-content;
        border: 0;
        padding: 0;
        color: var(--ink);
        background: transparent;
        font-weight: 900;
      }

      .menu-button {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
      }

      .menu-lines {
        width: 35px;
        display: grid;
        gap: 6px;
      }

      .menu-lines span {
        display: block;
        height: 2px;
        background: var(--ink);
      }

      .brand {
        justify-self: start;
        display: grid;
        justify-items: start;
        line-height: 1;
      }

      .brand strong {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.65rem, 3vw, 2.4rem);
        letter-spacing: -0.085em;
        font-weight: 500;
      }

      .brand span {
        margin-top: 0.25rem;
        color: var(--muted);
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        font-weight: 950;
      }

      .nav-email {
        justify-self: end;
      }

      .menu-overlay {
        position: fixed;
        inset: 0;
        z-index: 120;
        display: none;
        background:
          radial-gradient(circle at 20% 10%, rgba(166, 107, 53, 0.22), transparent 26rem),
          linear-gradient(135deg, #14110d, #21170f);
        color: var(--paper);
      }

      .menu-overlay.open {
        display: grid;
      }

      .menu-inner {
        display: grid;
        grid-template-columns: 0.72fr 1.28fr;
        min-height: 100vh;
      }

      .menu-info {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 2rem;
        padding: clamp(1.5rem, 4vw, 4rem);
        border-right: 1px solid var(--dark-line);
      }

      .close-menu {
        width: fit-content;
        border: 0;
        color: var(--paper);
        background: transparent;
        font-weight: 950;
      }

      .menu-info p {
        max-width: 410px;
        color: rgba(246, 240, 230, 0.68);
        line-height: 1.85;
      }

      .menu-list {
        display: grid;
        align-content: center;
        gap: 1.2rem;
        padding: clamp(1.5rem, 5vw, 5rem);
      }

      .menu-list a {
        display: grid;
        grid-template-columns: 76px 1fr;
        gap: 1rem;
        align-items: baseline;
        padding-bottom: 1.1rem;
        border-bottom: 1px solid var(--dark-line);
      }

      .menu-list small {
        color: rgba(246, 240, 230, 0.45);
        font-weight: 950;
      }

      .menu-list strong {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2.6rem, 7.6vw, 7rem);
        line-height: 0.86;
        letter-spacing: -0.095em;
        font-weight: 500;
      }

      .hero {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 0.86fr 1.14fr;
        gap: clamp(2rem, 5vw, 5.5rem);
        align-items: end;
        padding: 8rem clamp(1rem, 4vw, 4.8rem) 3rem;
      }

      .hero-copy {
        padding-bottom: clamp(1rem, 5vw, 5.8rem);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        margin-bottom: 1.35rem;
        padding: 0.52rem 0.82rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: var(--wood);
        background: rgba(255, 250, 242, 0.48);
        font-size: 0.78rem;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: 0.14em;
      }

      .eyebrow::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--bronze);
        box-shadow: 0 0 0 6px rgba(217, 168, 95, 0.16);
      }

      .hero h1 {
        margin: 0;
        max-width: 840px;
        font-size: clamp(4.3rem, 11vw, 11.2rem);
        line-height: 0.76;
        letter-spacing: -0.105em;
      }

      .hero h1 span {
        display: block;
        color: var(--wood);
      }

      .hero-text {
        max-width: 660px;
        margin: 1.7rem 0 0;
        color: var(--muted);
        font-size: clamp(1.04rem, 1.55vw, 1.23rem);
        line-height: 1.84;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 2rem;
      }

      .btn {
        min-height: 50px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        border-radius: 999px;
        padding: 0.92rem 1.18rem;
        border: 1px solid var(--line-strong);
        font-size: 0.9rem;
        font-weight: 950;
        transition:
          transform 0.2s ease,
          border-color 0.2s ease,
          background 0.2s ease;
      }

      .btn:hover {
        transform: translateY(-2px);
      }

      .btn-dark {
        color: var(--paper);
        background: var(--ink);
        border-color: var(--ink);
      }

      .btn-gold {
        color: #22160d;
        background: linear-gradient(135deg, #f2cf89, #c88d3f);
        border-color: rgba(139, 84, 31, 0.35);
      }

      .btn-light {
        color: var(--ink);
        background: rgba(255, 250, 242, 0.58);
      }

      .btn-outline-light {
        color: var(--paper);
        background: transparent;
        border-color: rgba(246, 240, 230, 0.32);
      }

      .hero-proof {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
        margin-top: 2rem;
        max-width: 660px;
      }

      .proof-pill {
        padding: 0.85rem;
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        background: rgba(255, 250, 242, 0.42);
      }

      .proof-pill strong {
        display: block;
        color: var(--ink);
        font-size: 0.95rem;
      }

      .proof-pill span {
        display: block;
        margin-top: 0.25rem;
        color: var(--muted);
        font-size: 0.78rem;
        line-height: 1.35;
      }

      .hero-gallery {
        display: grid;
        grid-template-columns: 1.14fr 0.86fr;
        gap: 1rem;
        align-items: end;
      }

      .image-card,
      .project-image,
      .feature-image,
      .visual-tile {
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
      }

      .image-card {
        position: relative;
        min-height: 74vh;
        overflow: hidden;
        box-shadow: var(--shadow);
        isolation: isolate;
      }

      .image-card.large {
        border-radius: 0 0 var(--radius-xl) var(--radius-xl);
      }

      .image-card.small {
        min-height: 50vh;
        border-radius: var(--radius-xl) var(--radius-xl) 0 0;
      }

      .image-card::before,
      .project-image::before,
      .feature-image::before,
      .visual-tile::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 1;
        background:
          linear-gradient(0deg, rgba(20, 17, 13, 0.56), transparent 56%),
          radial-gradient(circle at 28% 18%, rgba(255, 255, 255, 0.28), transparent 18rem);
      }

      .image-caption {
        position: absolute;
        z-index: 2;
        left: 1rem;
        right: 1rem;
        bottom: 1rem;
        padding: 1rem;
        border: 1px solid rgba(255, 250, 242, 0.52);
        border-radius: 28px;
        background: rgba(255, 250, 242, 0.82);
        backdrop-filter: blur(18px);
      }

      .image-caption strong {
        display: block;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.45rem, 2.7vw, 2.4rem);
        line-height: 0.95;
        letter-spacing: -0.065em;
      }

      .image-caption span {
        display: block;
        margin-top: 0.45rem;
        color: var(--muted);
        line-height: 1.55;
      }

      .section {
        padding: clamp(4.8rem, 8vw, 8.5rem) clamp(1rem, 4vw, 4.8rem);
      }

      .section-dark {
        margin-inline: clamp(1rem, 4vw, 4.8rem);
        border-radius: var(--radius-xl);
        background:
          radial-gradient(circle at 12% 10%, rgba(166, 107, 53, 0.25), transparent 26rem),
          linear-gradient(135deg, #15110d, #23180f);
        color: var(--paper);
        box-shadow: var(--shadow-dark);
      }

      .section-title {
        display: grid;
        grid-template-columns: 130px 1fr;
        gap: 1rem;
        align-items: start;
        margin-bottom: 2.2rem;
      }

      .section-title small {
        color: var(--wood);
        font-weight: 950;
        letter-spacing: 0.13em;
        text-transform: uppercase;
      }

      .section-dark .section-title small {
        color: var(--bronze);
      }

      .section-title h2 {
        margin: 0;
        max-width: 1120px;
        font-size: clamp(3.1rem, 7.8vw, 8.2rem);
        line-height: 0.82;
        letter-spacing: -0.1em;
      }

      .intro-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(1rem, 4vw, 4rem);
        border-top: 1px solid var(--line);
        padding-top: 2.2rem;
      }

      .intro-quote {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2rem, 4.2vw, 4.3rem);
        line-height: 1.04;
        letter-spacing: -0.065em;
      }

      .intro-text {
        margin: 0;
        color: var(--muted);
        font-size: clamp(1.05rem, 1.45vw, 1.2rem);
        line-height: 1.9;
      }

      .trust-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-top: 2.2rem;
      }

      .trust-card {
        min-height: 240px;
        display: grid;
        align-content: space-between;
        padding: 1.25rem;
        border: 1px solid rgba(246, 240, 230, 0.14);
        border-radius: var(--radius-lg);
        background: rgba(255, 250, 242, 0.06);
      }

      .trust-card .value {
        color: var(--bronze);
        font-weight: 950;
      }

      .trust-card h3 {
        margin: 2rem 0 0;
        font-size: clamp(1.65rem, 3vw, 2.5rem);
        line-height: 0.95;
        letter-spacing: -0.065em;
      }

      .trust-card p {
        margin: 0.8rem 0 0;
        color: rgba(246, 240, 230, 0.68);
        line-height: 1.7;
      }

      .project-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border-top: 1px solid var(--line);
        border-left: 1px solid var(--line);
      }

      .project-card {
        display: grid;
        min-height: 660px;
        align-content: space-between;
        background: rgba(255, 250, 242, 0.26);
        border-right: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .project-image {
        position: relative;
        min-height: 380px;
        overflow: hidden;
      }

      .project-content {
        padding: 1.45rem;
      }

      .project-tag {
        margin-bottom: 1rem;
        color: var(--wood);
        font-weight: 950;
      }

      .project-content h3 {
        margin: 0;
        font-size: clamp(2.1rem, 3.8vw, 4.1rem);
        line-height: 0.9;
        letter-spacing: -0.08em;
      }

      .project-content p {
        margin: 1rem 0 0;
        color: var(--muted);
        line-height: 1.72;
      }

      .split-feature {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: clamp(1rem, 4vw, 4rem);
        align-items: stretch;
      }

      .feature-image {
        position: relative;
        min-height: 720px;
        overflow: hidden;
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow);
      }

      .feature-image::after {
        content: "Made to fit";
        position: absolute;
        z-index: 2;
        left: 1.2rem;
        bottom: 1.2rem;
        padding: 0.72rem 1rem;
        border-radius: 999px;
        color: var(--ink);
        background: rgba(255, 250, 242, 0.82);
        font-weight: 950;
        backdrop-filter: blur(14px);
      }

      .feature-copy {
        display: grid;
        align-content: center;
        padding-block: 2rem;
      }

      .feature-copy h2 {
        margin: 0;
        font-size: clamp(3.2rem, 8vw, 8rem);
        line-height: 0.82;
        letter-spacing: -0.095em;
      }

      .feature-copy p {
        max-width: 720px;
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.9;
      }

      .service-list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        margin-top: 2rem;
        border-top: 1px solid var(--line);
        border-left: 1px solid var(--line);
      }

      .service-item {
        padding: 1.1rem;
        border-right: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        background: rgba(255, 250, 242, 0.32);
        font-weight: 950;
      }

      .visual-strip {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr 1fr;
        gap: 1rem;
        margin-top: 2.5rem;
      }

      .visual-tile {
        position: relative;
        min-height: 430px;
        overflow: hidden;
        border-radius: var(--radius-lg);
      }

      .visual-tile:nth-child(2) {
        margin-top: 4rem;
      }

      .visual-tile span {
        position: absolute;
        z-index: 2;
        left: 1rem;
        bottom: 1rem;
        display: inline-flex;
        padding: 0.62rem 0.85rem;
        border-radius: 999px;
        background: rgba(255, 250, 242, 0.82);
        color: var(--ink);
        font-weight: 950;
        backdrop-filter: blur(14px);
      }

      .process-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        border-top: 1px solid rgba(246, 240, 230, 0.15);
        padding-top: 2rem;
      }

      .process-card {
        min-height: 260px;
        display: grid;
        align-content: space-between;
        padding: 1.15rem;
        border: 1px solid rgba(246, 240, 230, 0.14);
        border-radius: var(--radius-lg);
        background: rgba(255, 250, 242, 0.06);
      }

      .process-card small {
        color: var(--bronze);
        font-weight: 950;
      }

      .process-card h3 {
        margin: 2.2rem 0 0;
        font-size: clamp(1.7rem, 3vw, 2.7rem);
        line-height: 0.95;
        letter-spacing: -0.065em;
      }

      .process-card p {
        color: rgba(246, 240, 230, 0.68);
        line-height: 1.7;
      }

      .estimate-section {
        scroll-margin-top: 110px;
      }

      .estimate-builder {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: clamp(1rem, 4vw, 4rem);
        border-top: 1px solid var(--line);
        padding-top: 2rem;
      }

      .estimate-panel {
        padding: clamp(1rem, 3vw, 2rem);
        border: 1px solid var(--line);
        border-radius: 42px;
        background: rgba(255, 250, 242, 0.36);
        box-shadow: var(--shadow);
      }

      .estimate-form {
        display: grid;
        gap: 1.1rem;
      }

      .estimate-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }

      .field {
        display: grid;
        gap: 0.45rem;
      }

      .field label,
      .field-title {
        color: var(--wood);
        font-weight: 950;
        font-size: 0.9rem;
      }

      .input,
      .select,
      .textarea {
        width: 100%;
        min-height: 50px;
        border: 1px solid var(--line-strong);
        border-radius: 18px;
        padding: 0.85rem 1rem;
        color: var(--ink);
        background: rgba(255, 250, 242, 0.74);
        outline: none;
      }

      .textarea {
        min-height: 122px;
        resize: vertical;
        line-height: 1.5;
      }

      .input:focus,
      .select:focus,
      .textarea:focus {
        border-color: var(--wood);
        box-shadow: 0 0 0 4px rgba(166, 107, 53, 0.13);
      }

      .photo-box {
        display: grid;
        gap: 0.8rem;
        padding: 1rem;
        border: 1px dashed var(--line-strong);
        border-radius: 24px;
        background: rgba(255, 250, 242, 0.46);
      }

      .photo-box p {
        margin: 0;
        color: var(--muted);
        line-height: 1.6;
      }

      .photo-list {
        display: grid;
        gap: 0.75rem;
      }

      .photo-list-text {
        color: var(--wood);
        font-size: 0.9rem;
        font-weight: 850;
      }

      .photo-preview-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
      }

      .photo-preview-card {
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: rgba(255, 250, 242, 0.68);
      }

      .photo-preview-card img {
        display: block;
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
      }

      .photo-preview-card span {
        display: block;
        padding: 0.55rem;
        color: var(--muted);
        font-size: 0.74rem;
        font-weight: 800;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
      }

      .checkbox-grid,
      .colour-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
      }

      .check-card,
      .colour-card {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        min-height: 56px;
        padding: 0.85rem;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: rgba(255, 250, 242, 0.54);
        font-weight: 850;
      }

      .check-card input,
      .colour-card input {
        width: 18px;
        height: 18px;
        accent-color: var(--wood);
      }

      .colour-card {
        align-items: flex-start;
      }

      .colour-card strong {
        display: block;
        line-height: 1.1;
      }

      .colour-card small {
        display: block;
        margin-top: 0.25rem;
        color: var(--muted);
        font-weight: 700;
        line-height: 1.35;
      }

      .swatch {
        width: 22px;
        height: 22px;
        flex: 0 0 22px;
        margin-top: 0.1rem;
        border: 1px solid rgba(20, 17, 13, 0.24);
        border-radius: 999px;
      }

      .swatch-white { background: #f7f4ea; }
      .swatch-grey { background: #b8b6ae; }
      .swatch-black { background: #171717; }
      .swatch-oak { background: #b9824b; }
      .swatch-gloss { background: linear-gradient(135deg, #ffffff, #d9d9d9, #ffffff); }
      .swatch-other { background: linear-gradient(135deg, #a66b35, #5d654c); }

      .estimate-preview-card {
        display: grid;
        align-content: space-between;
        gap: 1.2rem;
        padding: clamp(1rem, 3vw, 2rem);
        border-radius: 42px;
        color: var(--paper);
        background:
          radial-gradient(circle at 15% 10%, rgba(217, 168, 95, 0.20), transparent 20rem),
          var(--ink);
        box-shadow: var(--shadow-dark);
      }

      .estimate-preview-card h3 {
        margin: 0;
        font-size: clamp(2.2rem, 4vw, 4.3rem);
        line-height: 0.88;
        letter-spacing: -0.08em;
      }

      .estimate-preview-card p {
        margin: 0;
        color: rgba(246, 240, 230, 0.68);
        line-height: 1.75;
      }

      .estimate-preview {
        min-height: 270px;
        white-space: pre-wrap;
        overflow-wrap: break-word;
        padding: 1rem;
        border: 1px solid rgba(246, 240, 230, 0.14);
        border-radius: 24px;
        color: rgba(246, 240, 230, 0.9);
        background: rgba(255, 250, 242, 0.08);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.86rem;
        line-height: 1.65;
      }

      .estimate-note {
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.7;
      }

      .testimonial-lab {
        display: grid;
        grid-template-columns: 1.08fr 0.92fr;
        gap: clamp(1rem, 4vw, 4rem);
        align-items: start;
        border-top: 1px solid var(--line);
        padding-top: 2rem;
      }

      .testimonial-stack {
        perspective: 1400px;
      }

      .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .testimonial-card {
        min-height: 285px;
        display: grid;
        align-content: space-between;
        gap: 1.2rem;
        padding: 1.35rem;
        border: 1px solid rgba(255, 250, 242, 0.42);
        border-radius: var(--radius-lg);
        background:
          linear-gradient(145deg, rgba(255, 250, 242, 0.82), rgba(238, 226, 210, 0.46)),
          radial-gradient(circle at 20% 10%, rgba(217, 168, 95, 0.20), transparent 16rem);
        box-shadow:
          0 24px 55px rgba(33, 23, 12, 0.15),
          inset 0 1px 0 rgba(255, 255, 255, 0.72),
          inset 0 -18px 38px rgba(70, 42, 18, 0.06);
        transform-style: preserve-3d;
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease,
          border-color 0.25s ease;
      }

      .testimonial-card:nth-child(1) { transform: rotateY(-7deg) rotateX(3deg); }
      .testimonial-card:nth-child(2) { transform: translateY(22px) rotateY(0deg) rotateX(2deg); }
      .testimonial-card:nth-child(3) { transform: rotateY(7deg) rotateX(3deg); }

      .testimonial-card:hover {
        transform: translateY(-8px) rotateY(0deg) rotateX(0deg) scale(1.015);
        border-color: rgba(217, 168, 95, 0.72);
        box-shadow:
          0 36px 80px rgba(33, 23, 12, 0.24),
          inset 0 1px 0 rgba(255, 255, 255, 0.84);
      }

      .testimonial-stars {
        color: #9b642f;
        font-weight: 950;
        letter-spacing: 0.12em;
      }

      .testimonial-card p {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.35rem, 2.35vw, 2.05rem);
        line-height: 1.08;
        letter-spacing: -0.055em;
      }

      .testimonial-meta {
        display: grid;
        gap: 0.2rem;
      }

      .testimonial-meta strong {
        color: var(--wood);
      }

      .testimonial-meta span {
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 800;
      }

      .testimonial-form-card {
        position: sticky;
        top: 112px;
        display: grid;
        gap: 1rem;
        padding: clamp(1.1rem, 3vw, 2rem);
        border-radius: 42px;
        color: var(--paper);
        background:
          radial-gradient(circle at 20% 0%, rgba(217, 168, 95, 0.22), transparent 20rem),
          linear-gradient(145deg, #21170f, #100d0a);
        box-shadow: var(--shadow-dark);
        transform: rotateX(1deg) rotateY(-2deg);
        transform-style: preserve-3d;
      }

      .testimonial-form-card::before {
        content: "";
        position: absolute;
        inset: 14px;
        z-index: -1;
        border-radius: 36px;
        background: rgba(217, 168, 95, 0.16);
        filter: blur(24px);
        transform: translateZ(-24px);
      }

      .testimonial-form-card h3 {
        margin: 0;
        font-size: clamp(2.2rem, 4vw, 4.2rem);
        line-height: 0.88;
        letter-spacing: -0.08em;
      }

      .testimonial-form-card p {
        margin: 0;
        color: rgba(246, 240, 230, 0.68);
        line-height: 1.75;
      }

      .testimonial-form {
        display: grid;
        gap: 0.9rem;
      }

      .testimonial-form .input,
      .testimonial-form .select,
      .testimonial-form .textarea {
        color: var(--paper);
        border-color: rgba(246, 240, 230, 0.18);
        background: rgba(255, 250, 242, 0.08);
      }

      .testimonial-form .input::placeholder,
      .testimonial-form .textarea::placeholder {
        color: rgba(246, 240, 230, 0.42);
      }

      .testimonial-form .field label {
        color: rgba(246, 240, 230, 0.88);
      }

      .testimonial-form-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
      }

      .testimonial-form-note {
        color: rgba(246, 240, 230, 0.56);
        font-size: 0.88rem;
        line-height: 1.6;
      }

      .quote-section {
        display: grid;
        grid-template-columns: 1fr 0.82fr;
        min-height: 640px;
        margin: 0 clamp(1rem, 4vw, 4.8rem) clamp(4.8rem, 8vw, 8rem);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .quote-copy {
        display: grid;
        align-content: center;
        padding: clamp(2rem, 5vw, 5rem) 0;
      }

      .quote-copy h2 {
        margin: 0;
        max-width: 840px;
        font-size: clamp(3.6rem, 9vw, 9rem);
        line-height: 0.78;
        letter-spacing: -0.105em;
      }

      .quote-copy p {
        max-width: 660px;
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.9;
      }

      .contact-card {
        display: grid;
        align-content: space-between;
        margin: clamp(2rem, 4vw, 4rem) 0 clamp(2rem, 4vw, 4rem) clamp(1rem, 4vw, 4rem);
        padding: 1.4rem;
        border-radius: var(--radius-xl);
        color: var(--paper);
        background:
          radial-gradient(circle at 20% 10%, rgba(217, 168, 95, 0.18), transparent 20rem),
          var(--ink);
        box-shadow: var(--shadow-dark);
      }

      .contact-card h3 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 4rem);
        line-height: 0.88;
        letter-spacing: -0.08em;
      }

      .contact-card p {
        color: rgba(246, 240, 230, 0.68);
        line-height: 1.75;
      }

      .contact-actions {
        display: grid;
        gap: 0.8rem;
      }

      .contact-card .btn-light {
        color: var(--ink);
        background: var(--paper);
        border-color: var(--paper);
      }

      .footer {
        display: grid;
        grid-template-columns: 1.2fr 1fr 1fr;
        gap: 2rem;
        padding: clamp(2rem, 5vw, 4.8rem);
        border-top: 1px solid var(--line);
        color: var(--muted);
      }

      .footer strong {
        display: block;
        margin-bottom: 0.7rem;
        color: var(--ink);
      }

      .footer a,
      .footer button {
        display: block;
        width: fit-content;
        border: 0;
        padding: 0;
        margin-top: 0.35rem;
        color: var(--muted);
        background: transparent;
      }

      .toast {
        position: fixed;
        left: 50%;
        bottom: 2rem;
        z-index: 140;
        max-width: calc(100vw - 2rem);
        padding: 0.9rem 1.1rem;
        border-radius: 999px;
        color: var(--paper);
        background: var(--ink);
        font-weight: 950;
        box-shadow: var(--shadow);
        transform: translateX(-50%) translateY(18px);
        opacity: 0;
        pointer-events: none;
        transition: 0.25s ease;
      }

      .toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      .mobile-sticky {
        display: none;
      }

      @media (max-width: 1180px) {
        .hero,
        .split-feature,
        .quote-section,
        .menu-inner,
        .estimate-builder {
          grid-template-columns: 1fr;
        }

        .hero-gallery {
          grid-template-columns: 1fr;
        }

        .image-card,
        .image-card.small,
        .feature-image {
          min-height: 540px;
          border-radius: var(--radius-xl);
        }

        .project-grid,
        .trust-grid,
        .process-grid,
        .testimonials-grid {
          grid-template-columns: 1fr 1fr;
        }

        .contact-card {
          margin-left: 0;
        }

        .footer {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 760px) {
        .nav {
          grid-template-columns: auto 1fr auto;
          padding: 0.85rem 1rem;
        }

        .nav-links {
          position: fixed;
          left: 0.85rem;
          right: 0.85rem;
          top: 4.5rem;
          justify-self: stretch;
          display: flex;
          overflow-x: auto;
          gap: 0.35rem;
          padding: 0.38rem;
          border-radius: 18px;
          background: rgba(246, 240, 230, 0.92);
          scrollbar-width: none;
        }

        .nav-links::-webkit-scrollbar {
          display: none;
        }

        .nav-links a {
          flex: 0 0 auto;
          min-height: 36px;
          padding: 0.55rem 0.75rem;
          font-size: 0.78rem;
        }

        .brand {
          justify-self: start;
        }

        .brand strong {
          font-size: 1.32rem;
        }

        .brand span,
        .nav-email,
        .menu-button > span:last-child {
          display: none;
        }

        .section,
        .quote-section {
          scroll-margin-top: 128px;
        }

        .hero {
          padding: 9.4rem 1rem 2rem;
        }

        .hero h1 {
          font-size: clamp(4rem, 20vw, 6.5rem);
        }

        .hero-actions,
        .hero-proof {
          display: grid;
          grid-template-columns: 1fr;
        }

        .btn {
          width: 100%;
        }

        .section {
          padding: 4rem 1rem;
        }

        .section-dark {
          margin-inline: 1rem;
          border-radius: var(--radius-lg);
        }

        .section-title {
          grid-template-columns: 1fr;
        }

        .section-title h2,
        .feature-copy h2,
        .quote-copy h2 {
          font-size: clamp(3.25rem, 17vw, 5.8rem);
        }

        .intro-grid,
        .service-list,
        .estimate-grid,
        .checkbox-grid,
        .colour-grid,
        .project-grid,
        .trust-grid,
        .process-grid,
        .testimonials-grid,
        .visual-strip {
          grid-template-columns: 1fr;
        }

        .visual-tile:nth-child(2) {
          margin-top: 0;
        }

        .photo-preview-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .project-card {
          min-height: auto;
        }

        .project-image {
          min-height: 285px;
        }

        .quote-section {
          margin-inline: 1rem;
        }

        .menu-info {
          border-right: 0;
          border-bottom: 1px solid var(--dark-line);
        }

        .menu-list {
          padding: 1.5rem;
        }

        .menu-list a {
          grid-template-columns: 46px 1fr;
        }

        .menu-list strong {
          font-size: clamp(2.4rem, 15vw, 4.6rem);
        }

        .mobile-sticky {
          position: fixed;
          left: 0.85rem;
          right: 0.85rem;
          bottom: 0.85rem;
          z-index: 90;
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 0.65rem;
          padding: 0.6rem;
          border: 1px solid var(--line);
          border-radius: 22px;
          background: rgba(246, 240, 230, 0.88);
          box-shadow: var(--shadow);
          backdrop-filter: blur(18px);
        }

        .mobile-sticky .btn {
          min-height: 44px;
          padding: 0.75rem 0.8rem;
          font-size: 0.84rem;
        }

        .footer {
          padding-bottom: 6.5rem;
        }
      }
    </style>
  </head>

  <body>
    <div class="site">
      <nav class="nav">
        <button class="menu-button" type="button" data-open-menu>
          <span class="menu-lines">
            <span></span>
            <span></span>
          </span>
          <span>Menu</span>
        </button>

        <a class="brand" href="/" aria-label="WhichwoodFitters home">
          <strong>Whichwood</strong>
          <span>Fitters</span>
        </a>

        <div class="nav-links" aria-label="Quick section navigation">
          <a href="#work">Work</a>
          <a href="#why">Why Us</a>
          <a href="#process">Process</a>
          <a class="nav-quote-link" href="#estimate">Estimate</a>
          <a href="#reviews">Reviews</a>
          <a href="#quote">Contact</a>
        </div>

        <button class="nav-email" type="button" data-copy-email>
          {email}
        </button>
      </nav>

      <div class="menu-overlay" id="menuOverlay">
        <div class="menu-inner">
          <div class="menu-info">
            <button class="close-menu" type="button" data-close-menu>
              Close
            </button>

            <p>
              WhichwoodFitters designs and installs premium custom kitchens,
              cupboards, wardrobes, TV units, vanities and fitted storage made
              around exact measurements.
            </p>

            <a class="btn btn-gold" href={whatsappLink} target="_blank" rel="noopener noreferrer">
              WhatsApp {displayPhone}
            </a>
          </div>

          <div class="menu-list">
            <a href="#work" data-menu-link>
              <small>01</small>
              <strong>Work</strong>
            </a>

            <a href="#why" data-menu-link>
              <small>02</small>
              <strong>Why Us</strong>
            </a>

            <a href="#process" data-menu-link>
              <small>03</small>
              <strong>Process</strong>
            </a>

            <a href="#estimate" data-menu-link>
              <small>04</small>
              <strong>Estimate</strong>
            </a>

            <a href="/gallery" data-menu-link>
              <small>05</small>
              <strong>Gallery</strong>
            </a>

            <a href="#quote" data-menu-link>
              <small>06</small>
              <strong>Contact</strong>
            </a>
          </div>
        </div>
      </div>

      <main>
        <section class="hero">
          <div class="hero-copy">
            <span class="eyebrow">Premium fitted carpentry</span>

            <h1>
              Custom spaces
              <span>built properly.</span>
            </h1>

            <p class="hero-text">
              WhichwoodFitters creates custom kitchens, built-in cupboards,
              wardrobes, TV units and fitted storage for homes that need better
              function, cleaner lines and a stronger finish.
            </p>

            <div class="hero-actions">
              <a class="btn btn-gold" href={whatsappLink} target="_blank" rel="noopener noreferrer">
                WhatsApp for a quote
              </a>

              <a class="btn btn-dark" href="#estimate">
                Build fast estimate
              </a>

              <a class="btn btn-light" href="/gallery">
                View gallery
              </a>
            </div>

            <div class="hero-proof">
              <div class="proof-pill">
                <strong>Made to measure</strong>
                <span>Built around your exact space</span>
              </div>

              <div class="proof-pill">
                <strong>Modern finishes</strong>
                <span>Melamine, wood-look, gloss and more</span>
              </div>

              <div class="proof-pill">
                <strong>Clean install</strong>
                <span>Practical, strong and neat</span>
              </div>
            </div>
          </div>

          <div class="hero-gallery">
            <div class="image-card large" style={`background-image: url('/images/hero-main.jpg');`}>
              <div class="image-caption">
                <strong>Kitchens, cupboards & fitted interiors</strong>
                <span>Premium storage made for real homes and daily use.</span>
              </div>
            </div>

            <div class="image-card small" style={`background-image: url('/images/hero-small.jpg');`}>
              <div class="image-caption">
                <strong>Measured first</strong>
                <span>Walls, corners, plugs and ceiling heights all matter.</span>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="why">
          <div class="section-title">
            <small>Philosophy</small>
            <h2>Good carpentry starts before the first board is cut.</h2>
          </div>

          <div class="intro-grid">
            <p class="intro-quote">
              A fitted unit should feel like it was always meant to be there.
            </p>

            <p class="intro-text">
              We focus on accurate measuring, strong layouts, practical storage,
              honest material choices and neat installation. The goal is simple:
              to turn unused or messy spaces into clean, useful, fitted interiors.
            </p>
          </div>
        </section>

        <section class="section section-dark">
          <div class="section-title">
            <small>Trust</small>
            <h2>Built for people who want it done right.</h2>
          </div>

          <div class="trust-grid">
            {trustItems.map((item) => (
              <article class="trust-card">
                <div class="value">{item.value}</div>
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="section" id="work">
          <div class="section-title">
            <small>Featured Work</small>
            <h2>Custom builds for kitchens, bedrooms and living spaces.</h2>
          </div>

          <div class="project-grid">
            {featuredProjects.map((project) => (
              <article class="project-card">
                <div class="project-image" style={`background-image: url('${project.image}');`}></div>

                <div class="project-content">
                  <div class="project-tag">{project.tag}</div>
                  <h3>{project.title}</h3>
                  <p>{project.text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="section">
          <div class="split-feature">
            <div class="feature-image" style={`background-image: url('/images/service.jpg');`}></div>

            <div class="feature-copy">
              <span class="eyebrow">Services</span>
              <h2>From idea to fitted result.</h2>

              <p>
                Send photos, rough measurements, finish ideas and your location.
                The clearer the space, the cleaner the quote and the fewer
                expensive surprises later.
              </p>

              <div class="service-list">
                {services.map((service) => (
                  <div class="service-item">{service}</div>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section class="section section-dark" id="process">
          <div class="section-title">
            <small>Process</small>
            <h2>Simple steps from first photo to final fit.</h2>
          </div>

          <div class="process-grid">
            {processSteps.map((step) => (
              <article class="process-card">
                <small>{step.no}</small>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.text}</p>
                </div>
              </article>
            ))}
          </div>

          <div class="visual-strip">
            <div class="visual-tile" style={`background-image: url('/images/kitchen.jpg');`}>
              <span>Kitchen storage</span>
            </div>

            <div class="visual-tile" style={`background-image: url('/images/cupboards.jpg');`}>
              <span>Wardrobes</span>
            </div>

            <div class="visual-tile" style={`background-image: url('/images/tv-unit.jpg');`}>
              <span>Interior units</span>
            </div>
          </div>
        </section>

        <section class="section estimate-section" id="estimate">
          <div class="section-title">
            <small>Fast Estimate</small>
            <h2>Send the right details for a faster quote.</h2>
          </div>

          <div class="estimate-builder">
            <form class="estimate-panel estimate-form" id="estimateForm">
              <div class="field">
                <label for="projectType">Project type</label>
                <select class="select" id="projectType">
                  <option value="Kitchen">Kitchen</option>
                  <option value="Built-in cupboards">Built-in cupboards</option>
                  <option value="Wardrobe">Wardrobe</option>
                  <option value="TV unit">TV unit</option>
                  <option value="Bathroom vanity">Bathroom vanity</option>
                  <option value="Storage solution">Storage solution</option>
                  <option value="Custom melamine work">Custom melamine work</option>
                </select>
              </div>

              <div class="photo-box">
                <div>
                  <div class="field-title">Photos</div>
                  <p>
                    Take or upload photos of the full wall, close-up corners,
                    plugs, pipes, ceiling and the area where the unit must fit.
                  </p>
                </div>

                <input
                  class="input"
                  id="estimatePhotos"
                  type="file"
                  accept="image/*"
                  capture="environment"
                  multiple
                />

                <div class="photo-list" id="selectedPhotos">
                  <div class="photo-list-text">No photos selected yet.</div>
                </div>

                <p class="estimate-note">
                  On mobile, the button will try to share the selected photos and message together.
                  Choose WhatsApp when your phone asks where to share.
                </p>
              </div>

              <div class="estimate-grid">
                <div class="field">
                  <label for="widthMeasure">Width</label>
                  <input class="input" id="widthMeasure" type="text" placeholder="Example: 3200mm" />
                </div>

                <div class="field">
                  <label for="heightMeasure">Height</label>
                  <input class="input" id="heightMeasure" type="text" placeholder="Example: 2400mm" />
                </div>

                <div class="field">
                  <label for="depthMeasure">Depth</label>
                  <input class="input" id="depthMeasure" type="text" placeholder="Example: 600mm" />
                </div>
              </div>

              <div class="field">
                <div class="field-title">What must we see in the photos?</div>

                <div class="checkbox-grid">
                  <label class="check-card">
                    <input type="checkbox" name="siteDetails" value="Plugs" />
                    Plugs
                  </label>

                  <label class="check-card">
                    <input type="checkbox" name="siteDetails" value="Pipes" />
                    Pipes
                  </label>

                  <label class="check-card">
                    <input type="checkbox" name="siteDetails" value="Corners" />
                    Corners
                  </label>

                  <label class="check-card">
                    <input type="checkbox" name="siteDetails" value="Ceiling height" />
                    Ceiling height
                  </label>

                  <label class="check-card">
                    <input type="checkbox" name="siteDetails" value="Skirting" />
                    Skirting
                  </label>

                  <label class="check-card">
                    <input type="checkbox" name="siteDetails" value="Uneven wall or floor" />
                    Uneven wall/floor
                  </label>
                </div>
              </div>

              <div class="field">
                <div class="field-title">Colour / finish option</div>

                <div class="colour-grid">
                  <label class="colour-card">
                    <input type="radio" name="finishOption" value="White melamine" checked />
                    <span class="swatch swatch-white"></span>
                    <span>
                      <strong>White</strong>
                      <small>Clean, bright, modern</small>
                    </span>
                  </label>

                  <label class="colour-card">
                    <input type="radio" name="finishOption" value="Light grey melamine" />
                    <span class="swatch swatch-grey"></span>
                    <span>
                      <strong>Light Grey</strong>
                      <small>Soft neutral finish</small>
                    </span>
                  </label>

                  <label class="colour-card">
                    <input type="radio" name="finishOption" value="Black melamine" />
                    <span class="swatch swatch-black"></span>
                    <span>
                      <strong>Black</strong>
                      <small>Bold premium look</small>
                    </span>
                  </label>

                  <label class="colour-card">
                    <input type="radio" name="finishOption" value="Oak / wood-look melamine" />
                    <span class="swatch swatch-oak"></span>
                    <span>
                      <strong>Oak / Wood Look</strong>
                      <small>Warm natural style</small>
                    </span>
                  </label>

                  <label class="colour-card">
                    <input type="radio" name="finishOption" value="SupaGloss / high-gloss finish" />
                    <span class="swatch swatch-gloss"></span>
                    <span>
                      <strong>SupaGloss</strong>
                      <small>Gloss modern finish</small>
                    </span>
                  </label>

                  <label class="colour-card">
                    <input type="radio" name="finishOption" value="Other finish / not sure yet" />
                    <span class="swatch swatch-other"></span>
                    <span>
                      <strong>Other</strong>
                      <small>Need advice</small>
                    </span>
                  </label>
                </div>
              </div>

              <div class="field">
                <label for="estimateNotes">Extra notes</label>
                <textarea
                  class="textarea"
                  id="estimateNotes"
                  placeholder="Example: Need drawers, hanging space, shelves, soft-close hinges, LED lighting, or matching existing cupboards."
                ></textarea>
              </div>
            </form>

            <div class="estimate-preview-card">
              <div>
                <h3>Your WhatsApp request.</h3>
                <p>
                  This message updates while the client fills in the form. When
                  they click the button, WhatsApp opens with the quote details ready.
                </p>
              </div>

              <pre class="estimate-preview" id="estimatePreview"></pre>

              <button class="btn btn-gold" id="estimateWhatsAppButton" type="button">
                Share photos + estimate to WhatsApp
              </button>

              <p>
                Best on mobile. If the browser blocks file sharing, WhatsApp will open with the message only.
              </p>
            </div>
          </div>
        </section>

        <section class="section" id="reviews">
          <div class="section-title">
            <small>Reviews</small>
            <h2>Real words from people who trust fitted work.</h2>
          </div>

          <div class="testimonial-lab">
            <div class="testimonial-stack">
              <div class="testimonials-grid" id="testimonialsGrid">
                {testimonials.map((testimonial) => (
                  <article class="testimonial-card">
                    <div class="testimonial-stars">★★★★★</div>
                    <p>“{testimonial.quote}”</p>
                    <div class="testimonial-meta">
                      <strong>{testimonial.name}</strong>
                      <span>WhichwoodFitters client</span>
                    </div>
                  </article>
                ))}
              </div>
            </div>

            <aside class="testimonial-form-card" aria-label="Add a testimonial">
              <div>
                <span class="eyebrow">Add Your Testimonial</span>
                <h3>Leave a review.</h3>
                <p>
                  Clients can write a quick review here. It saves permanently and appears publicly after approval.
                </p>
              </div>

              <form class="testimonial-form" id="testimonialForm">
                <input id="testimonialCompany" name="company" type="text" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0;" aria-hidden="true" />
                <div class="field">
                  <label for="testimonialName">Your name</label>
                  <input class="input" id="testimonialName" type="text" placeholder="Example: Johan" required />
                </div>

                <div class="field">
                  <label for="testimonialProject">Project type</label>
                  <select class="select" id="testimonialProject">
                    <option value="Kitchen">Kitchen</option>
                    <option value="Built-in cupboards">Built-in cupboards</option>
                    <option value="Wardrobe">Wardrobe</option>
                    <option value="TV unit">TV unit</option>
                    <option value="Vanity">Vanity</option>
                    <option value="Custom storage">Custom storage</option>
                  </select>
                </div>

                <div class="field">
                  <label for="testimonialRating">Rating</label>
                  <select class="select" id="testimonialRating">
                    <option value="5">★★★★★ 5 stars</option>
                    <option value="4">★★★★☆ 4 stars</option>
                    <option value="3">★★★☆☆ 3 stars</option>
                  </select>
                </div>

                <div class="field">
                  <label for="testimonialMessage">Your testimonial</label>
                  <textarea class="textarea" id="testimonialMessage" maxlength="220" placeholder="Example: Neat installation, great finish and the cupboards fit perfectly." required></textarea>
                </div>

                <div class="testimonial-form-actions">
                  <button class="btn btn-light" type="submit">Submit Review</button>
                  <button class="btn btn-outline-light" id="testimonialWhatsAppButton" type="button">Send WhatsApp</button>
                </div>

                <div class="testimonial-form-note">
                  Reviews are stored permanently and stay private until approved. This protects the site from spam and fake reviews.
                </div>
              </form>
            </aside>
          </div>
        </section>

        <section class="quote-section" id="quote">
          <div class="quote-copy">
            <span class="eyebrow">Personal Quote</span>
            <h2>Send your space.</h2>

            <p>
              WhatsApp is the fastest way. Send photos, rough measurements,
              finish ideas and your location. You can also copy the email address
              or open your email app.
            </p>
          </div>

          <div class="contact-card">
            <div>
              <h3>WhichwoodFitters</h3>
              <p>
                Custom kitchens, built-in cupboards, wardrobes, TV units,
                vanities and fitted storage.
              </p>
            </div>

            <div class="contact-actions">
              <a class="btn btn-gold" href={whatsappLink} target="_blank" rel="noopener noreferrer">
                WhatsApp {displayPhone}
              </a>

              <a class="btn btn-outline-light" href="#estimate">
                Build estimate
              </a>

              <a class="btn btn-outline-light" href="/gallery">
                View gallery
              </a>

              <button class="btn btn-outline-light" type="button" data-copy-email>
                Copy {email}
              </button>

              <a class="btn btn-outline-light" href={mailLink}>
                Open email app
              </a>
            </div>
          </div>
        </section>
      </main>

      <footer class="footer">
        <div>
          <strong>WhichwoodFitters</strong>
          <span>Premium custom carpentry and fitted storage.</span>
        </div>

        <div>
          <strong>Contact</strong>
          <a href={whatsappLink} target="_blank" rel="noopener noreferrer">
            WhatsApp {displayPhone}
          </a>
          <button type="button" data-copy-email>{email}</button>
        </div>

        <div>
          <strong>Pages</strong>
          <a href="/">Home</a>
          <a href="/gallery">Gallery</a>
          <a href="#estimate">Fast Estimate</a>
        </div>
      </footer>

      <div class="mobile-sticky">
        <a class="btn btn-light" href="#estimate">
          Estimate
        </a>

        <a class="btn btn-dark" href={whatsappLink} target="_blank" rel="noopener noreferrer">
          WhatsApp
        </a>
      </div>

      <div class="toast" id="emailToast" role="status" aria-live="polite">
        Email copied: {email}
      </div>
    </div>

    <script define:vars={{ email, mailLink, whatsappNumber }}>
      const openMenuButton = document.querySelector("[data-open-menu]");
      const closeMenuButton = document.querySelector("[data-close-menu]");
      const menuOverlay = document.getElementById("menuOverlay");
      const menuLinks = document.querySelectorAll("[data-menu-link]");
      const copyButtons = document.querySelectorAll("[data-copy-email]");
      const toast = document.getElementById("emailToast");

      const estimateForm = document.getElementById("estimateForm");
      const estimatePhotos = document.getElementById("estimatePhotos");
      const selectedPhotos = document.getElementById("selectedPhotos");
      const estimatePreview = document.getElementById("estimatePreview");
      const estimateWhatsAppButton = document.getElementById("estimateWhatsAppButton");
      const testimonialForm = document.getElementById("testimonialForm");
      const testimonialName = document.getElementById("testimonialName");
      const testimonialProject = document.getElementById("testimonialProject");
      const testimonialRating = document.getElementById("testimonialRating");
      const testimonialMessage = document.getElementById("testimonialMessage");
      const testimonialsGrid = document.getElementById("testimonialsGrid");
      const testimonialWhatsAppButton = document.getElementById("testimonialWhatsAppButton");
      const testimonialCompany = document.getElementById("testimonialCompany");

      let activePhotoUrls = [];

      function openMenu() {
        if (!menuOverlay) return;
        menuOverlay.classList.add("open");
        document.body.style.overflow = "hidden";
      }

      function closeMenu() {
        if (!menuOverlay) return;
        menuOverlay.classList.remove("open");
        document.body.style.overflow = "";
      }

      function showToast(message) {
        if (!toast) return;

        toast.textContent = message;
        toast.classList.add("show");

        window.setTimeout(() => {
          toast.classList.remove("show");
        }, 2400);
      }

      function fallbackCopy(text) {
        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        textarea.style.top = "0";

        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();

        const successful = document.execCommand("copy");
        document.body.removeChild(textarea);

        return successful;
      }

      async function copyEmail() {
        try {
          if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText(email);
          } else {
            const copied = fallbackCopy(email);

            if (!copied) {
              throw new Error("Fallback copy failed.");
            }
          }

          showToast(`Email copied: ${email}`);
        } catch {
          showToast(`Email: ${email}`);

          window.setTimeout(() => {
            window.location.href = mailLink;
          }, 900);
        }
      }

      function getInputValue(id) {
        const element = document.getElementById(id);
        const value = element?.value?.trim();

        return value && value.length > 0 ? value : "Not supplied";
      }

      function getCheckedValues(name) {
        const checked = Array.from(document.querySelectorAll(`input[name="${name}"]:checked`))
          .map((input) => input.value);

        return checked.length > 0 ? checked.join(", ") : "Not supplied";
      }

      function getSelectedFinish() {
        const selected = document.querySelector('input[name="finishOption"]:checked');
        return selected?.value || "Not supplied";
      }

      function getSelectedPhotoFiles() {
        return Array.from(estimatePhotos?.files || []);
      }

      function getSelectedPhotoNames() {
        return getSelectedPhotoFiles().map((file) => file.name);
      }

      function clearPhotoUrls() {
        activePhotoUrls.forEach((url) => URL.revokeObjectURL(url));
        activePhotoUrls = [];
      }

      function updateSelectedPhotos() {
        if (!selectedPhotos) return;

        clearPhotoUrls();

        const files = getSelectedPhotoFiles();
        selectedPhotos.replaceChildren();

        if (files.length === 0) {
          const emptyText = document.createElement("div");
          emptyText.className = "photo-list-text";
          emptyText.textContent = "No photos selected yet.";
          selectedPhotos.appendChild(emptyText);
          return;
        }

        const countText = document.createElement("div");
        countText.className = "photo-list-text";
        countText.textContent = `${files.length} photo(s) selected and ready to share.`;
        selectedPhotos.appendChild(countText);

        const previewGrid = document.createElement("div");
        previewGrid.className = "photo-preview-grid";

        files.forEach((file, index) => {
          const imageUrl = URL.createObjectURL(file);
          activePhotoUrls.push(imageUrl);

          const card = document.createElement("div");
          card.className = "photo-preview-card";

          const image = document.createElement("img");
          image.src = imageUrl;
          image.alt = `Selected estimate photo ${index + 1}`;

          const label = document.createElement("span");
          label.textContent = `${index + 1}. ${file.name}`;

          card.appendChild(image);
          card.appendChild(label);
          previewGrid.appendChild(card);
        });

        selectedPhotos.appendChild(previewGrid);
      }

      function buildEstimateMessage() {
        const projectType = getInputValue("projectType");
        const width = getInputValue("widthMeasure");
        const height = getInputValue("heightMeasure");
        const depth = getInputValue("depthMeasure");
        const visibleDetails = getCheckedValues("siteDetails");
        const finish = getSelectedFinish();
        const notes = getInputValue("estimateNotes");
        const photos = getSelectedPhotoNames();

        const photoText =
          photos.length > 0
            ? `${photos.length} photo(s) selected. I will attach them in WhatsApp.`
            : "No photos selected yet. I still need to attach photos.";

        const message =
`Hi WhichwoodFitters, I need a fast estimate.

Project type: ${projectType}

Measurements:
Width: ${width}
Height: ${height}
Depth: ${depth}

Photos:
${photoText}

Please check these in the photos:
${visibleDetails}

Colour / finish:
${finish}

Extra notes:
${notes}

Location:
Not supplied yet.

Please let me know what else you need for the quote.`;

        if (estimatePreview) {
          estimatePreview.textContent = message;
        }

        return message;
      }

      async function openEstimateWhatsApp() {
        const message = buildEstimateMessage();
        const files = getSelectedPhotoFiles();

        try {
          if (
            files.length > 0 &&
            navigator.canShare &&
            navigator.share &&
            navigator.canShare({ files })
          ) {
            await navigator.share({
              title: "WhichwoodFitters Estimate Request",
              text: message,
              files
            });

            showToast("Photos and estimate shared. Choose WhatsApp if asked.");
            return;
          }
        } catch {
          showToast("Photo sharing was cancelled or blocked.");
        }

        const link = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`;
        window.open(link, "_blank", "noopener,noreferrer");

        if (files.length > 0) {
          showToast("WhatsApp opened with text. Attach the selected photos manually if they did not share.");
        } else {
          showToast("WhatsApp estimate request opened.");
        }
      }

      function getStars(rating) {
        const safeRating = Math.max(1, Math.min(5, Number(rating) || 5));
        return "★".repeat(safeRating) + "☆".repeat(5 - safeRating);
      }

      function createTestimonialCard(testimonial, placement = "append") {
        if (!testimonialsGrid) return;

        const card = document.createElement("article");
        card.className = "testimonial-card";

        const stars = document.createElement("div");
        stars.className = "testimonial-stars";
        stars.textContent = getStars(testimonial.rating);

        const quote = document.createElement("p");
        quote.textContent = `“${testimonial.message}”`;

        const meta = document.createElement("div");
        meta.className = "testimonial-meta";

        const name = document.createElement("strong");
        name.textContent = testimonial.name || "WhichwoodFitters client";

        const project = document.createElement("span");
        project.textContent = testimonial.project || "Custom carpentry";

        meta.appendChild(name);
        meta.appendChild(project);

        card.appendChild(stars);
        card.appendChild(quote);
        card.appendChild(meta);

        if (placement === "prepend") {
          testimonialsGrid.prepend(card);
        } else {
          testimonialsGrid.appendChild(card);
        }
      }

      async function loadDatabaseTestimonials() {
        if (!testimonialsGrid) return;

        try {
          const response = await fetch("/api/testimonials", {
            method: "GET",
            headers: {
              "Accept": "application/json"
            }
          });

          if (!response.ok) {
            throw new Error("Could not load testimonials.");
          }

          const data = await response.json();
          const testimonials = Array.isArray(data.testimonials) ? data.testimonials : [];

          if (testimonials.length === 0) {
            return;
          }

          testimonialsGrid.replaceChildren();
          testimonials.forEach((testimonial) => createTestimonialCard(testimonial));
        } catch {
          // Keep the built-in starter reviews visible if the database is not ready yet.
        }
      }

      function getTestimonialData() {
        return {
          name: testimonialName?.value?.trim() || "Happy client",
          project: testimonialProject?.value || "Custom carpentry",
          rating: testimonialRating?.value || "5",
          message: testimonialMessage?.value?.trim() || "Great service and a clean finish.",
          company: testimonialCompany?.value?.trim() || ""
        };
      }

      function buildTestimonialWhatsAppMessage() {
        const testimonial = getTestimonialData();
        return `Hi WhichwoodFitters, I want to leave a testimonial.

Name: ${testimonial.name}
Project: ${testimonial.project}
Rating: ${getStars(testimonial.rating)}

Testimonial:
${testimonial.message}`;
      }

      async function addTestimonial(event) {
        event?.preventDefault();

        const testimonial = getTestimonialData();

        if (testimonial.company) {
          showToast("Review submitted.");
          testimonialForm?.reset();
          return;
        }

        if (!testimonial.message || testimonial.message.length < 8) {
          showToast("Please write a slightly longer testimonial.");
          return;
        }

        try {
          const response = await fetch("/api/testimonials", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "Accept": "application/json"
            },
            body: JSON.stringify(testimonial)
          });

          const result = await response.json().catch(() => ({}));

          if (!response.ok) {
            throw new Error(result.error || "Could not submit review.");
          }

          testimonialForm?.reset();
          showToast("Review saved. It will show after approval.");
        } catch {
          showToast("Review could not save. Send it on WhatsApp instead.");
        }
      }

      function sendTestimonialToWhatsApp() {
        const message = buildTestimonialWhatsAppMessage();
        const link = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`;
        window.open(link, "_blank", "noopener,noreferrer");
      }

      openMenuButton?.addEventListener("click", openMenu);
      closeMenuButton?.addEventListener("click", closeMenu);

      menuLinks.forEach((link) => {
        link.addEventListener("click", closeMenu);
      });

      copyButtons.forEach((button) => {
        button.addEventListener("click", copyEmail);
      });

      estimatePhotos?.addEventListener("change", () => {
        updateSelectedPhotos();
        buildEstimateMessage();
      });

      estimateForm?.addEventListener("input", buildEstimateMessage);
      estimateForm?.addEventListener("change", buildEstimateMessage);

      estimateWhatsAppButton?.addEventListener("click", openEstimateWhatsApp);
      testimonialForm?.addEventListener("submit", addTestimonial);
      testimonialWhatsAppButton?.addEventListener("click", sendTestimonialToWhatsApp);

      loadDatabaseTestimonials();
      buildEstimateMessage();

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeMenu();
        }
      });

      window.addEventListener("beforeunload", clearPhotoUrls);
    </script>
  </body>
</html>
