---
const email = "ruhantait@yahoo.com";
const displayPhone = "079 910 1465";
const whatsappNumber = "27799101465";

const whatsappMessage = encodeURIComponent(
  "Hi WhichwoodFitters, I would like a quote for custom carpentry. I can send photos and measurements."
);

const whatsappLink = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;

const emailSubject = "Quote request - WhichwoodFitters";

const emailBody =
  "Hi WhichwoodFitters,\n\nI would like a quote for custom carpentry.\n\nProject type:\nMeasurements:\nPhotos attached:\nLocation:\n\nThank you.";

const mailLink = `mailto:${email}?subject=${encodeURIComponent(emailSubject)}&body=${encodeURIComponent(emailBody)}`;

const products = [
  {
    number: "01",
    title: "Kitchens",
    subtitle: "Designed around real homes",
    text: "Modern kitchens built around storage, workflow, appliances, finishes, and the exact space available."
  },
  {
    number: "02",
    title: "Built-In Cupboards",
    subtitle: "Wall-to-wall fitted storage",
    text: "Bedroom cupboards, wardrobes, linen cupboards, and practical storage made to fit cleanly and properly."
  },
  {
    number: "03",
    title: "TV Units",
    subtitle: "Clean living-room details",
    text: "Floating TV units, media walls, shelving, cable-friendly storage, and modern display solutions."
  }
];

const services = [
  "Site measuring",
  "Layout planning",
  "Material advice",
  "Custom manufacture",
  "Clean installation",
  "After-job support"
];

const finishes = [
  "White melamine",
  "Iceberg white",
  "Nordic white",
  "Woodgrain melamine",
  "Black accents",
  "Soft-close hinges",
  "Modern handles",
  "Push-to-open doors"
];

const news = [
  {
    title: "Send photos for a faster quote",
    text: "Stand back and show the full wall, then send close-ups of plugs, corners, pipes, floors, and ceiling height."
  },
  {
    title: "Choose finishes before pricing",
    text: "White, woodgrain, black accents, and soft-close hardware can change the quote, so finish choice matters."
  },
  {
    title: "Measure width, height, and depth",
    text: "Rough measurements help start the estimate, but final measurements must be confirmed before production."
  }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>WhichwoodFitters | Custom Kitchens, Cupboards & Carpentry</title>

    <meta
      name="description"
      content="WhichwoodFitters designs and installs custom kitchens, built-in cupboards, wardrobes, TV units, vanities, and fitted storage."
    />

    <style>
      :root {
        --paper: #f3eee4;
        --paper-2: #ebe2d2;
        --ink: #1e1913;
        --muted: #756b5f;
        --soft: #a89a89;
        --wood: #9b6a38;
        --wood-dark: #4b2d18;
        --olive: #606c4d;
        --line: rgba(30, 25, 19, 0.16);
        --line-strong: rgba(30, 25, 19, 0.28);
        --white: #fffaf1;
        --shadow: 0 30px 90px rgba(45, 32, 18, 0.16);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        color: var(--ink);
        background:
          radial-gradient(circle at 15% 5%, rgba(155, 106, 56, 0.16), transparent 28rem),
          radial-gradient(circle at 90% 15%, rgba(96, 108, 77, 0.12), transparent 26rem),
          linear-gradient(135deg, var(--paper), var(--paper-2));
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.18;
        background-image:
          linear-gradient(rgba(30, 25, 19, 0.12) 1px, transparent 1px),
          linear-gradient(90deg, rgba(30, 25, 19, 0.12) 1px, transparent 1px);
        background-size: 82px 82px;
        mask-image: linear-gradient(to bottom, black, transparent 85%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      .site {
        position: relative;
        z-index: 1;
      }

      .nav {
        position: fixed;
        inset: 0 0 auto;
        z-index: 50;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
        padding: 1.1rem clamp(1rem, 4vw, 4.5rem);
        background: rgba(243, 238, 228, 0.78);
        border-bottom: 1px solid rgba(30, 25, 19, 0.1);
        backdrop-filter: blur(22px);
      }

      .menu-button,
      .nav-contact {
        width: fit-content;
        border: 0;
        background: transparent;
        color: var(--ink);
        cursor: pointer;
        font-weight: 750;
        letter-spacing: 0.02em;
      }

      .menu-button {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
      }

      .menu-lines {
        width: 34px;
        display: grid;
        gap: 6px;
      }

      .menu-lines span {
        height: 2px;
        background: var(--ink);
        display: block;
      }

      .brand {
        justify-self: center;
        display: grid;
        justify-items: center;
        line-height: 1;
      }

      .brand strong {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.55rem, 3vw, 2.35rem);
        letter-spacing: -0.08em;
        font-weight: 500;
      }

      .brand span {
        margin-top: 0.28rem;
        color: var(--muted);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-weight: 750;
      }

      .nav-contact {
        justify-self: end;
      }

      .menu-overlay {
        position: fixed;
        inset: 0;
        z-index: 80;
        display: none;
        background: var(--ink);
        color: var(--paper);
      }

      .menu-overlay.open {
        display: grid;
      }

      .menu-inner {
        display: grid;
        grid-template-columns: 0.75fr 1.25fr;
        min-height: 100vh;
      }

      .menu-side {
        padding: clamp(1.4rem, 4vw, 4rem);
        border-right: 1px solid rgba(255, 255, 255, 0.15);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .close-menu {
        width: fit-content;
        border: 0;
        color: var(--paper);
        background: transparent;
        cursor: pointer;
        font-size: 1rem;
        font-weight: 800;
      }

      .menu-side p {
        color: rgba(243, 238, 228, 0.68);
        line-height: 1.7;
        max-width: 380px;
      }

      .menu-links {
        padding: clamp(1.4rem, 5vw, 5rem);
        display: grid;
        align-content: center;
        gap: 1.2rem;
      }

      .menu-links a {
        display: grid;
        grid-template-columns: 72px 1fr;
        gap: 1rem;
        align-items: baseline;
        padding-bottom: 1.1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.14);
      }

      .menu-links small {
        color: rgba(243, 238, 228, 0.45);
        font-weight: 850;
      }

      .menu-links strong {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2.4rem, 7vw, 6.8rem);
        line-height: 0.9;
        letter-spacing: -0.085em;
        font-weight: 500;
      }

      .hero {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: clamp(2rem, 5vw, 5.5rem);
        align-items: end;
        padding: 8rem clamp(1rem, 4vw, 4.5rem) 3rem;
      }

      .hero-copy {
        padding-bottom: clamp(1rem, 5vw, 5rem);
      }

      .eyebrow {
        display: inline-flex;
        margin-bottom: 1.2rem;
        padding: 0.55rem 0.85rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: var(--wood-dark);
        background: rgba(255, 250, 241, 0.42);
        font-size: 0.82rem;
        font-weight: 850;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      h1,
      h2,
      h3 {
        font-family: Georgia, "Times New Roman", serif;
        font-weight: 500;
      }

      .hero h1 {
        margin: 0;
        font-size: clamp(4rem, 12vw, 11rem);
        line-height: 0.78;
        letter-spacing: -0.095em;
      }

      .hero h1 span {
        display: block;
        color: var(--wood);
      }

      .hero-text {
        max-width: 640px;
        margin: 1.5rem 0 0;
        color: var(--muted);
        font-size: clamp(1.05rem, 1.6vw, 1.22rem);
        line-height: 1.75;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-top: 2rem;
      }

      .btn {
        min-height: 48px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        border-radius: 999px;
        padding: 0.9rem 1.18rem;
        border: 1px solid var(--line-strong);
        cursor: pointer;
        font-size: 0.92rem;
        font-weight: 850;
        transition:
          transform 0.2s ease,
          background 0.2s ease,
          border-color 0.2s ease;
      }

      .btn:hover {
        transform: translateY(-2px);
      }

      .btn-dark {
        background: var(--ink);
        color: var(--paper);
        border-color: var(--ink);
      }

      .btn-light {
        background: rgba(255, 250, 241, 0.5);
        color: var(--ink);
      }

      .hero-visual {
        position: relative;
        min-height: 72vh;
        border-radius: 0 0 44px 44px;
        overflow: hidden;
        box-shadow: var(--shadow);
        background:
          linear-gradient(90deg, rgba(255, 255, 255, 0.28), transparent 35%),
          repeating-linear-gradient(
            90deg,
            #70431f 0,
            #70431f 22px,
            #8e5b2d 22px,
            #8e5b2d 48px,
            #ad7840 48px,
            #ad7840 76px
          );
      }

      .hero-visual::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(0deg, rgba(30, 25, 19, 0.5), transparent 48%),
          radial-gradient(circle at 25% 18%, rgba(255, 255, 255, 0.32), transparent 20rem);
      }

      .visual-card {
        position: absolute;
        left: 1.2rem;
        right: 1.2rem;
        bottom: 1.2rem;
        padding: 1.2rem;
        border-radius: 28px;
        background: rgba(255, 250, 241, 0.84);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(255, 250, 241, 0.6);
      }

      .visual-card h2 {
        margin: 0;
        font-size: clamp(1.6rem, 3vw, 2.6rem);
        line-height: 1;
        letter-spacing: -0.055em;
      }

      .visual-card p {
        color: var(--muted);
        line-height: 1.65;
        margin: 0.7rem 0 0;
      }

      .section {
        padding: clamp(4.5rem, 8vw, 8rem) clamp(1rem, 4vw, 4.5rem);
      }

      .section-label {
        display: grid;
        grid-template-columns: 110px 1fr;
        gap: 1rem;
        align-items: start;
        margin-bottom: 2rem;
      }

      .section-label small {
        color: var(--muted);
        font-weight: 900;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .section-label h2 {
        margin: 0;
        max-width: 1060px;
        font-size: clamp(3rem, 8vw, 8rem);
        line-height: 0.82;
        letter-spacing: -0.09em;
      }

      .intro-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(1rem, 4vw, 4rem);
        align-items: start;
        border-top: 1px solid var(--line);
        padding-top: 2rem;
      }

      .intro-grid p {
        margin: 0;
        color: var(--muted);
        font-size: clamp(1.05rem, 1.5vw, 1.25rem);
        line-height: 1.85;
      }

      .quote-line {
        font-family: Georgia, "Times New Roman", serif;
        color: var(--ink) !important;
        font-size: clamp(1.8rem, 4vw, 4rem) !important;
        line-height: 1.05 !important;
        letter-spacing: -0.055em;
      }

      .product-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border-top: 1px solid var(--line);
        border-left: 1px solid var(--line);
      }

      .product-card {
        min-height: 620px;
        display: grid;
        align-content: space-between;
        border-right: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        background: rgba(255, 250, 241, 0.22);
      }

      .product-image {
        min-height: 340px;
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(90deg, rgba(255, 255, 255, 0.22), transparent 40%),
          repeating-linear-gradient(
            90deg,
            #72502f 0,
            #72502f 16px,
            #91683f 16px,
            #91683f 36px,
            #b08352 36px,
            #b08352 56px
          );
      }

      .product-card:nth-child(2) .product-image {
        background:
          linear-gradient(120deg, rgba(30, 25, 19, 0.14), transparent 40%),
          repeating-linear-gradient(
            90deg,
            #e6dfd2 0,
            #e6dfd2 26px,
            #fff8ed 26px,
            #fff8ed 54px
          );
      }

      .product-card:nth-child(3) .product-image {
        background:
          radial-gradient(circle at 30% 20%, rgba(255,255,255,0.24), transparent 16rem),
          linear-gradient(135deg, #2c2923, #72614d);
      }

      .product-image::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(0deg, rgba(30, 25, 19, 0.38), transparent 58%),
          radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.28), transparent 18rem);
      }

      .product-content {
        padding: 1.5rem;
      }

      .product-number {
        color: var(--wood);
        font-weight: 950;
        margin-bottom: 1rem;
      }

      .product-content h3 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 4rem);
        line-height: 0.9;
        letter-spacing: -0.075em;
      }

      .product-content h4 {
        margin: 0.9rem 0 0;
        color: var(--wood-dark);
        font-size: 1rem;
      }

      .product-content p {
        color: var(--muted);
        line-height: 1.7;
      }

      .split-feature {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: clamp(1rem, 4vw, 4rem);
        align-items: stretch;
      }

      .feature-art {
        min-height: 680px;
        position: relative;
        overflow: hidden;
        border-radius: 44px;
        box-shadow: var(--shadow);
        background:
          linear-gradient(0deg, rgba(30, 25, 19, 0.38), transparent 50%),
          repeating-linear-gradient(
            90deg,
            #6d401e 0,
            #6d401e 22px,
            #875225 22px,
            #875225 48px,
            #a0692f 48px,
            #a0692f 72px
          );
      }

      .feature-art::after {
        content: "Made to fit";
        position: absolute;
        left: 1.3rem;
        bottom: 1.3rem;
        padding: 0.75rem 1rem;
        border-radius: 999px;
        background: rgba(255, 250, 241, 0.78);
        color: var(--ink);
        font-weight: 900;
        backdrop-filter: blur(14px);
      }

      .feature-copy {
        display: grid;
        align-content: center;
        padding-block: 2rem;
      }

      .feature-copy h2 {
        margin: 0;
        font-size: clamp(3rem, 8vw, 8rem);
        line-height: 0.82;
        letter-spacing: -0.09em;
      }

      .feature-copy p {
        max-width: 720px;
        color: var(--muted);
        font-size: 1.12rem;
        line-height: 1.85;
      }

      .service-list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0;
        border-top: 1px solid var(--line);
        border-left: 1px solid var(--line);
        margin-top: 2rem;
      }

      .service-item {
        padding: 1.1rem;
        border-right: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        font-weight: 850;
        color: var(--ink);
        background: rgba(255, 250, 241, 0.25);
      }

      .news-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }

      .news-card {
        min-height: 260px;
        display: grid;
        align-content: space-between;
        padding: 1.35rem;
        border: 1px solid var(--line);
        background: rgba(255, 250, 241, 0.32);
      }

      .news-card small {
        color: var(--wood);
        font-weight: 950;
      }

      .news-card h3 {
        margin: 1rem 0 0;
        font-size: clamp(1.7rem, 3vw, 3rem);
        line-height: 0.94;
        letter-spacing: -0.065em;
      }

      .news-card p {
        color: var(--muted);
        line-height: 1.7;
      }

      .finish-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        margin-top: 2rem;
      }

      .finish-pill {
        padding: 0.78rem 1rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 250, 241, 0.34);
        color: var(--muted);
        font-weight: 800;
      }

      .consultation {
        margin: 0 clamp(1rem, 4vw, 4.5rem) clamp(4.5rem, 8vw, 8rem);
        display: grid;
        grid-template-columns: 1fr 0.85fr;
        min-height: 620px;
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .consult-copy {
        padding: clamp(2rem, 5vw, 5rem) 0;
        display: grid;
        align-content: center;
      }

      .consult-copy h2 {
        margin: 0;
        font-size: clamp(3.4rem, 9vw, 9rem);
        line-height: 0.8;
        letter-spacing: -0.095em;
      }

      .consult-copy p {
        max-width: 660px;
        color: var(--muted);
        line-height: 1.85;
        font-size: 1.1rem;
      }

      .consult-card {
        margin: clamp(2rem, 4vw, 4rem) 0 clamp(2rem, 4vw, 4rem) clamp(1rem, 4vw, 4rem);
        padding: 1.4rem;
        display: grid;
        align-content: space-between;
        background: var(--ink);
        color: var(--paper);
        border-radius: 44px;
        box-shadow: var(--shadow);
      }

      .consult-card h3 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 4rem);
        line-height: 0.9;
        letter-spacing: -0.075em;
      }

      .contact-actions {
        display: grid;
        gap: 0.8rem;
      }

      .consult-card .btn-light {
        background: var(--paper);
        color: var(--ink);
        border-color: var(--paper);
      }

      .consult-card .btn-outline {
        color: var(--paper);
        border-color: rgba(243, 238, 228, 0.32);
        background: transparent;
      }

      .footer {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 2rem;
        padding: clamp(2rem, 5vw, 4.5rem);
        border-top: 1px solid var(--line);
        color: var(--muted);
      }

      .footer strong {
        display: block;
        color: var(--ink);
        margin-bottom: 0.7rem;
      }

      .footer a,
      .footer button {
        display: block;
        width: fit-content;
        border: 0;
        padding: 0;
        color: var(--muted);
        background: transparent;
        cursor: pointer;
        margin-top: 0.35rem;
      }

      .toast {
        position: fixed;
        left: 50%;
        bottom: 2rem;
        z-index: 100;
        transform: translateX(-50%) translateY(18px);
        opacity: 0;
        pointer-events: none;
        padding: 0.9rem 1.1rem;
        border-radius: 999px;
        background: var(--ink);
        color: var(--paper);
        font-weight: 900;
        box-shadow: var(--shadow);
        transition: 0.25s ease;
      }

      .toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      .mobile-sticky {
        display: none;
      }

      @media (max-width: 1080px) {
        .hero,
        .split-feature,
        .consultation,
        .menu-inner {
          grid-template-columns: 1fr;
        }

        .hero-visual,
        .feature-art {
          min-height: 520px;
        }

        .product-grid,
        .news-grid {
          grid-template-columns: 1fr;
        }

        .product-card {
          min-height: auto;
        }

        .consult-card {
          margin-left: 0;
        }

        .footer {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 720px) {
        .nav {
          grid-template-columns: auto 1fr auto;
          padding: 0.85rem 1rem;
        }

        .brand {
          justify-self: start;
        }

        .brand strong {
          font-size: 1.3rem;
        }

        .brand span,
        .nav-contact {
          display: none;
        }

        .hero {
          padding: 6.5rem 1rem 2rem;
        }

        .hero h1 {
          font-size: clamp(4rem, 20vw, 6.5rem);
        }

        .hero-actions,
        .service-list {
          grid-template-columns: 1fr;
        }

        .hero-actions {
          display: grid;
        }

        .btn {
          width: 100%;
        }

        .section {
          padding: 4rem 1rem;
        }

        .section-label {
          grid-template-columns: 1fr;
        }

        .section-label h2,
        .feature-copy h2,
        .consult-copy h2 {
          font-size: clamp(3.4rem, 17vw, 5.6rem);
        }

        .intro-grid {
          grid-template-columns: 1fr;
        }

        .product-image {
          min-height: 260px;
        }

        .consultation {
          margin-inline: 1rem;
        }

        .menu-side {
          border-right: 0;
          border-bottom: 1px solid rgba(255, 255, 255, 0.14);
          min-height: auto;
          gap: 2rem;
        }

        .menu-links {
          padding: 1.5rem;
        }

        .menu-links a {
          grid-template-columns: 44px 1fr;
        }

        .menu-links strong {
          font-size: clamp(2.4rem, 15vw, 4.4rem);
        }

        .mobile-sticky {
          position: fixed;
          left: 0.85rem;
          right: 0.85rem;
          bottom: 0.85rem;
          z-index: 60;
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 0.65rem;
          padding: 0.6rem;
          border-radius: 22px;
          background: rgba(243, 238, 228, 0.82);
          backdrop-filter: blur(18px);
          border: 1px solid var(--line);
          box-shadow: var(--shadow);
        }

        .mobile-sticky .btn {
          min-height: 44px;
          padding: 0.75rem 0.8rem;
          font-size: 0.85rem;
        }

        .footer {
          padding-bottom: 6.5rem;
        }
      }
    </style>
  </head>

  <body>
    <div class="site">
      <nav class="nav">
        <button class="menu-button" type="button" data-open-menu>
          <span class="menu-lines">
            <span></span>
            <span></span>
          </span>
          <span>Menu</span>
        </button>

        <a class="brand" href="/" aria-label="WhichwoodFitters home">
          <strong>Whichwood</strong>
          <span>Fitters</span>
        </a>

        <button class="nav-contact" type="button" data-copy-email>
          {email}
        </button>
      </nav>

      <div class="menu-overlay" id="menuOverlay">
        <div class="menu-inner">
          <div class="menu-side">
            <button class="close-menu" type="button" data-close-menu>
              Close
            </button>

            <p>
              WhichwoodFitters designs and installs custom kitchens, built-in
              cupboards, wardrobes, TV units, vanities, and storage solutions.
            </p>

            <div>
              <a class="btn btn-light" href={whatsappLink} target="_blank" rel="noopener noreferrer">
                WhatsApp {displayPhone}
              </a>
            </div>
          </div>

          <div class="menu-links">
            <a href="#products" data-menu-link>
              <small>01</small>
              <strong>Products</strong>
            </a>
            <a href="#philosophy" data-menu-link>
              <small>02</small>
              <strong>Philosophy</strong>
            </a>
            <a href="#service" data-menu-link>
              <small>03</small>
              <strong>Service</strong>
            </a>
            <a href="#quote" data-menu-link>
              <small>04</small>
              <strong>Contact</strong>
            </a>
          </div>
        </div>
      </div>

      <main>
        <section class="hero">
          <div class="hero-copy">
            <span class="eyebrow">Custom carpentry • South Africa</span>

            <h1>
              Connected
              <span>with wood</span>
            </h1>

            <p class="hero-text">
              Modern fitted furniture, kitchens, wardrobes, TV units and
              storage solutions — designed around your space, your finish, and
              your daily use.
            </p>

            <div class="hero-actions">
              <a class="btn btn-dark" href={whatsappLink} target="_blank" rel="noopener noreferrer">
                WhatsApp for quote
              </a>

              <button class="btn btn-light" type="button" data-copy-email>
                Copy email
              </button>

              <a class="btn btn-light" href={mailLink}>
                Open email app
              </a>
            </div>
          </div>

          <div class="hero-visual">
            <div class="visual-card">
              <h2>Design meets practical storage.</h2>
              <p>
                Built-in work should look clean, fit properly, and solve real
                storage problems without wasting space.
              </p>
            </div>
          </div>
        </section>

        <section class="section" id="philosophy">
          <div class="section-label">
            <small>Philosophy</small>
            <h2>Beautiful work starts with proper measurements.</h2>
          </div>

          <div class="intro-grid">
            <p class="quote-line">
              Every wall, corner, plug point and ceiling height matters.
            </p>

            <p>
              A good fitted unit is not only about how it looks. It must open
              properly, carry weight, hide clutter, handle daily use, and make
              the room feel calmer. WhichwoodFitters focuses on clean planning,
              realistic materials, and solid installation.
            </p>
          </div>
        </section>

        <section class="section" id="products">
          <div class="section-label">
            <small>Products</small>
            <h2>Designed for homes that need better storage.</h2>
          </div>

          <div class="product-grid">
            {products.map((product) => (
              <article class="product-card">
                <div class="product-image"></div>

                <div class="product-content">
                  <div class="product-number">{product.number}</div>
                  <h3>{product.title}</h3>
                  <h4>{product.subtitle}</h4>
                  <p>{product.text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="section" id="service">
          <div class="split-feature">
            <div class="feature-art"></div>

            <div class="feature-copy">
              <span class="eyebrow">Service</span>
              <h2>From idea to fitted result.</h2>
              <p>
                Send photos, rough measurements and the type of unit you want.
                The quote becomes clearer when the space, finish and purpose
                are clear from the start.
              </p>

              <div class="service-list">
                {services.map((service) => (
                  <div class="service-item">{service}</div>
                ))}
              </div>

              <div class="finish-strip">
                {finishes.map((finish) => (
                  <span class="finish-pill">{finish}</span>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section class="section">
          <div class="section-label">
            <small>Advice</small>
            <h2>Before you ask for a quote.</h2>
          </div>

          <div class="news-grid">
            {news.map((item, index) => (
              <article class="news-card">
                <div>
                  <small>{String(index + 1).padStart(2, "0")}</small>
                  <h3>{item.title}</h3>
                </div>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="consultation" id="quote">
          <div class="consult-copy">
            <span class="eyebrow">Personal quote</span>
            <h2>Send your space.</h2>
            <p>
              WhatsApp is the fastest way. Send photos, rough measurements,
              finish ideas and your location. You can also copy the email
              address or open your email app.
            </p>
          </div>

          <div class="consult-card">
            <div>
              <h3>WhichwoodFitters</h3>
              <p>
                Custom kitchens, built-in cupboards, wardrobes, TV units,
                vanities and fitted storage.
              </p>
            </div>

            <div class="contact-actions">
              <a class="btn btn-light" href={whatsappLink} target="_blank" rel="noopener noreferrer">
                WhatsApp {displayPhone}
              </a>

              <button class="btn btn-outline" type="button" data-copy-email>
                Copy {email}
              </button>

              <a class="btn btn-outline" href={mailLink}>
                Open email app
              </a>
            </div>
          </div>
        </section>
      </main>

      <footer class="footer">
        <div>
          <strong>WhichwoodFitters</strong>
          <span>Custom carpentry and fitted storage.</span>
        </div>

        <div>
          <strong>Contact</strong>
          <a href={whatsappLink} target="_blank" rel="noopener noreferrer">
            WhatsApp {displayPhone}
          </a>
          <button type="button" data-copy-email>{email}</button>
        </div>

        <div>
          <strong>Services</strong>
          <span>Kitchens • Cupboards • Wardrobes • TV units • Vanities</span>
        </div>
      </footer>

      <div class="mobile-sticky">
        <button class="btn btn-light" type="button" data-copy-email>
          Email
        </button>

        <a class="btn btn-dark" href={whatsappLink} target="_blank" rel="noopener noreferrer">
          WhatsApp
        </a>
      </div>

      <div class="toast" id="emailToast" role="status" aria-live="polite">
        Email copied: {email}
      </div>
    </div>

    <script define:vars={{ email, mailLink }}>
      const openMenuButton = document.querySelector("[data-open-menu]");
      const closeMenuButton = document.querySelector("[data-close-menu]");
      const menuOverlay = document.getElementById("menuOverlay");
      const menuLinks = document.querySelectorAll("[data-menu-link]");
      const copyButtons = document.querySelectorAll("[data-copy-email]");
      const toast = document.getElementById("emailToast");

      function openMenu() {
        if (!menuOverlay) return;
        menuOverlay.classList.add("open");
        document.body.style.overflow = "hidden";
      }

      function closeMenu() {
        if (!menuOverlay) return;
        menuOverlay.classList.remove("open");
        document.body.style.overflow = "";
      }

      function showToast(message) {
        if (!toast) return;

        toast.textContent = message;
        toast.classList.add("show");

        window.setTimeout(() => {
          toast.classList.remove("show");
        }, 2400);
      }

      function fallbackCopy(text) {
        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        textarea.style.top = "0";

        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();

        const successful = document.execCommand("copy");
        document.body.removeChild(textarea);

        return successful;
      }

      async function copyEmail() {
        try {
          if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText(email);
          } else {
            const copied = fallbackCopy(email);

            if (!copied) {
              throw new Error("Fallback copy failed.");
            }
          }

          showToast(`Email copied: ${email}`);
        } catch {
          showToast(`Email: ${email}`);

          window.setTimeout(() => {
            window.location.href = mailLink;
          }, 900);
        }
      }

      openMenuButton?.addEventListener("click", openMenu);
      closeMenuButton?.addEventListener("click", closeMenu);

      menuLinks.forEach((link) => {
        link.addEventListener("click", closeMenu);
      });

      copyButtons.forEach((button) => {
        button.addEventListener("click", copyEmail);
      });

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeMenu();
        }
      });
    </script>
  </body>
</html>
