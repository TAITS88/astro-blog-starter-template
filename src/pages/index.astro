---
const email = "ruhantait@yahoo.com";
const displayPhone = "079 910 1465";
const whatsappNumber = "27799101465";

const whatsappMessage = encodeURIComponent(
  "Hi WhichwoodFitters, I would like a quote for custom carpentry. I can send photos and measurements."
);

const whatsappLink = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;

const emailSubject = "Quote request - WhichwoodFitters";

const emailBody =
  "Hi WhichwoodFitters,\n\nI would like a quote for custom carpentry.\n\nProject type:\nMeasurements:\nPhotos attached:\nLocation:\n\nThank you.";

const mailLink = `mailto:${email}?subject=${encodeURIComponent(emailSubject)}&body=${encodeURIComponent(emailBody)}`;

const products = [
  {
    no: "01",
    title: "Kitchen Builds",
    subtitle: "Design meets daily use",
    text: "Fitted kitchens planned around storage, appliances, workflow, finishes and the exact room measurements.",
    image: "/images/kitchen.jpg"
  },
  {
    no: "02",
    title: "Built-In Cupboards",
    subtitle: "Storage made to fit",
    text: "Bedroom cupboards, wardrobes, linen cupboards and wall-to-wall fitted storage with clean practical layouts.",
    image: "/images/cupboards.jpg"
  },
  {
    no: "03",
    title: "Interior Units",
    subtitle: "Details that complete a room",
    text: "TV units, vanities, shelves, office units, laundry cupboards and custom storage for awkward spaces.",
    image: "/images/tv-unit.jpg"
  }
];

const services = [
  "Site measuring",
  "Layout planning",
  "Material guidance",
  "Custom manufacturing",
  "Clean installation",
  "After-job support"
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>WhichwoodFitters | Custom Kitchens, Cupboards & Fitted Storage</title>

    <meta
      name="description"
      content="WhichwoodFitters designs and installs custom kitchens, built-in cupboards, wardrobes, TV units, vanities and fitted storage."
    />

    <style>
      :root {
        --paper: #f4efe5;
        --paper-soft: #ebe1d1;
        --cream: #fffaf1;
        --ink: #201a13;
        --muted: #74695c;
        --soft: #9b8f80;
        --wood: #9a6535;
        --wood-dark: #4b2b16;
        --olive: #626a4f;
        --line: rgba(32, 26, 19, 0.16);
        --line-dark: rgba(32, 26, 19, 0.32);
        --shadow: 0 36px 110px rgba(58, 38, 18, 0.16);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--ink);
        background:
          radial-gradient(circle at 12% 5%, rgba(154, 101, 53, 0.15), transparent 30rem),
          radial-gradient(circle at 88% 14%, rgba(98, 106, 79, 0.12), transparent 28rem),
          linear-gradient(135deg, var(--paper), var(--paper-soft));
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.13;
        background-image:
          linear-gradient(rgba(32, 26, 19, 0.14) 1px, transparent 1px),
          linear-gradient(90deg, rgba(32, 26, 19, 0.14) 1px, transparent 1px);
        background-size: 86px 86px;
        mask-image: linear-gradient(to bottom, black, transparent 82%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      .site {
        position: relative;
        z-index: 1;
      }

      h1,
      h2,
      h3 {
        font-family: Georgia, "Times New Roman", serif;
        font-weight: 500;
      }

      .nav {
        position: fixed;
        inset: 0 0 auto;
        z-index: 50;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
        padding: 1.1rem clamp(1rem, 4vw, 4.8rem);
        background: rgba(244, 239, 229, 0.78);
        border-bottom: 1px solid rgba(32, 26, 19, 0.08);
        backdrop-filter: blur(22px);
      }

      .menu-button,
      .nav-email {
        border: 0;
        padding: 0;
        width: fit-content;
        color: var(--ink);
        background: transparent;
        cursor: pointer;
        font-weight: 800;
      }

      .menu-button {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
      }

      .menu-lines {
        width: 35px;
        display: grid;
        gap: 6px;
      }

      .menu-lines span {
        display: block;
        height: 2px;
        background: var(--ink);
      }

      .brand {
        justify-self: center;
        display: grid;
        justify-items: center;
        line-height: 1;
      }

      .brand strong {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.55rem, 3vw, 2.3rem);
        letter-spacing: -0.085em;
        font-weight: 500;
      }

      .brand span {
        margin-top: 0.28rem;
        color: var(--muted);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-weight: 850;
      }

      .nav-email {
        justify-self: end;
      }

      .menu-overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: none;
        background: var(--ink);
        color: var(--paper);
      }

      .menu-overlay.open {
        display: grid;
      }

      .menu-inner {
        display: grid;
        grid-template-columns: 0.72fr 1.28fr;
        min-height: 100vh;
      }

      .menu-info {
        padding: clamp(1.5rem, 4vw, 4rem);
        border-right: 1px solid rgba(255, 250, 241, 0.14);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .close-menu {
        width: fit-content;
        border: 0;
        background: transparent;
        color: var(--paper);
        cursor: pointer;
        font-weight: 850;
      }

      .menu-info p {
        max-width: 390px;
        color: rgba(244, 239, 229, 0.68);
        line-height: 1.8;
      }

      .menu-list {
        padding: clamp(1.5rem, 5vw, 5rem);
        display: grid;
        align-content: center;
        gap: 1.2rem;
      }

      .menu-list a {
        display: grid;
        grid-template-columns: 76px 1fr;
        gap: 1rem;
        align-items: baseline;
        padding-bottom: 1.15rem;
        border-bottom: 1px solid rgba(255, 250, 241, 0.14);
      }

      .menu-list small {
        color: rgba(244, 239, 229, 0.45);
        font-weight: 900;
      }

      .menu-list strong {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2.5rem, 7.5vw, 7rem);
        line-height: 0.86;
        letter-spacing: -0.095em;
        font-weight: 500;
      }

      .hero {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 0.85fr 1.15fr;
        gap: clamp(2rem, 5vw, 5.5rem);
        align-items: end;
        padding: 8rem clamp(1rem, 4vw, 4.8rem) 3rem;
      }

      .hero-copy {
        padding-bottom: clamp(1rem, 5vw, 5.5rem);
      }

      .page-label {
        display: inline-flex;
        margin-bottom: 1.4rem;
        padding: 0.54rem 0.85rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: var(--wood-dark);
        background: rgba(255, 250, 241, 0.42);
        font-size: 0.8rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.14em;
      }

      .hero h1 {
        margin: 0;
        font-size: clamp(4.4rem, 12vw, 11.6rem);
        line-height: 0.76;
        letter-spacing: -0.105em;
      }

      .hero h1 span {
        display: block;
        color: var(--wood);
      }

      .hero-text {
        max-width: 620px;
        margin: 1.6rem 0 0;
        color: var(--muted);
        font-size: clamp(1.05rem, 1.55vw, 1.22rem);
        line-height: 1.82;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 2rem;
      }

      .btn {
        min-height: 48px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        border-radius: 999px;
        padding: 0.9rem 1.18rem;
        border: 1px solid var(--line-dark);
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: 900;
        transition:
          transform 0.2s ease,
          background 0.2s ease,
          border-color 0.2s ease;
      }

      .btn:hover {
        transform: translateY(-2px);
      }

      .btn-dark {
        color: var(--paper);
        background: var(--ink);
        border-color: var(--ink);
      }

      .btn-light {
        color: var(--ink);
        background: rgba(255, 250, 241, 0.5);
      }

      .btn-outline-light {
        color: var(--paper);
        background: transparent;
        border-color: rgba(244, 239, 229, 0.34);
      }

      .hero-gallery {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 1rem;
        align-items: end;
      }

      .hero-image,
      .product-visual,
      .feature-image {
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
      }

      .hero-image {
        position: relative;
        min-height: 72vh;
        overflow: hidden;
        box-shadow: var(--shadow);
      }

      .hero-image.large {
        border-radius: 0 0 48px 48px;
      }

      .hero-image.small {
        min-height: 48vh;
        border-radius: 48px 48px 0 0;
      }

      .hero-image::before,
      .product-visual::after,
      .feature-image::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(0deg, rgba(32, 26, 19, 0.5), transparent 55%),
          radial-gradient(circle at 26% 18%, rgba(255, 255, 255, 0.28), transparent 20rem);
      }

      .image-caption {
        position: absolute;
        z-index: 2;
        left: 1rem;
        right: 1rem;
        bottom: 1rem;
        padding: 1rem;
        border-radius: 26px;
        background: rgba(255, 250, 241, 0.82);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(255, 250, 241, 0.55);
      }

      .image-caption strong {
        display: block;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.4rem, 2.5vw, 2.25rem);
        line-height: 0.95;
        letter-spacing: -0.06em;
      }

      .image-caption span {
        display: block;
        margin-top: 0.45rem;
        color: var(--muted);
        line-height: 1.55;
      }

      .section {
        padding: clamp(4.8rem, 8vw, 8.5rem) clamp(1rem, 4vw, 4.8rem);
      }

      .section-title {
        display: grid;
        grid-template-columns: 120px 1fr;
        gap: 1rem;
        align-items: start;
        margin-bottom: 2rem;
      }

      .section-title small {
        color: var(--muted);
        font-weight: 950;
        letter-spacing: 0.13em;
        text-transform: uppercase;
      }

      .section-title h2 {
        margin: 0;
        max-width: 1120px;
        font-size: clamp(3.2rem, 8vw, 8.3rem);
        line-height: 0.82;
        letter-spacing: -0.1em;
      }

      .intro-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(1rem, 4vw, 4rem);
        border-top: 1px solid var(--line);
        padding-top: 2.2rem;
      }

      .intro-quote {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2rem, 4.2vw, 4.2rem);
        line-height: 1.05;
        letter-spacing: -0.065em;
      }

      .intro-text {
        margin: 0;
        color: var(--muted);
        font-size: clamp(1.05rem, 1.45vw, 1.2rem);
        line-height: 1.9;
      }

      .product-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border-top: 1px solid var(--line);
        border-left: 1px solid var(--line);
      }

      .product-card {
        min-height: 630px;
        display: grid;
        align-content: space-between;
        background: rgba(255, 250, 241, 0.22);
        border-right: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .product-visual {
        position: relative;
        min-height: 350px;
        overflow: hidden;
      }

      .product-content {
        padding: 1.45rem;
      }

      .product-no {
        color: var(--wood);
        font-weight: 950;
        margin-bottom: 1rem;
      }

      .product-content h3 {
        margin: 0;
        font-size: clamp(2.1rem, 4vw, 4.2rem);
        line-height: 0.9;
        letter-spacing: -0.08em;
      }

      .product-content h4 {
        margin: 0.95rem 0 0;
        color: var(--wood-dark);
        font-size: 1rem;
      }

      .product-content p {
        margin: 1rem 0 0;
        color: var(--muted);
        line-height: 1.72;
      }

      .feature {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: clamp(1rem, 4vw, 4rem);
        align-items: stretch;
      }

      .feature-image {
        min-height: 700px;
        position: relative;
        overflow: hidden;
        border-radius: 48px;
        box-shadow: var(--shadow);
      }

      .feature-image::after {
        content: "Made to fit";
        position: absolute;
        z-index: 2;
        left: 1.2rem;
        bottom: 1.2rem;
        padding: 0.72rem 1rem;
        border-radius: 999px;
        background: rgba(255, 250, 241, 0.82);
        color: var(--ink);
        font-weight: 950;
        backdrop-filter: blur(14px);
      }

      .feature-copy {
        display: grid;
        align-content: center;
        padding-block: 2rem;
      }

      .feature-copy h2 {
        margin: 0;
        font-size: clamp(3.2rem, 8vw, 8rem);
        line-height: 0.82;
        letter-spacing: -0.095em;
      }

      .feature-copy p {
        max-width: 720px;
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.9;
      }

      .service-list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        border-top: 1px solid var(--line);
        border-left: 1px solid var(--line);
        margin-top: 2rem;
      }

      .service-item {
        padding: 1.1rem;
        background: rgba(255, 250, 241, 0.28);
        border-right: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        font-weight: 900;
      }

      .estimate-section {
        scroll-margin-top: 110px;
      }

      .estimate-builder {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: clamp(1rem, 4vw, 4rem);
        border-top: 1px solid var(--line);
        padding-top: 2rem;
      }

      .estimate-panel {
        padding: clamp(1rem, 3vw, 2rem);
        border: 1px solid var(--line);
        border-radius: 42px;
        background: rgba(255, 250, 241, 0.34);
        box-shadow: var(--shadow);
      }

      .estimate-form {
        display: grid;
        gap: 1.1rem;
      }

      .estimate-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }

      .field {
        display: grid;
        gap: 0.45rem;
      }

      .field label,
      .field-title {
        color: var(--wood-dark);
        font-weight: 950;
        font-size: 0.9rem;
      }

      .input,
      .select,
      .textarea {
        width: 100%;
        min-height: 48px;
        border: 1px solid var(--line-dark);
        border-radius: 18px;
        padding: 0.85rem 1rem;
        background: rgba(255, 250, 241, 0.72);
        color: var(--ink);
        outline: none;
        font: inherit;
      }

      .textarea {
        min-height: 120px;
        resize: vertical;
        line-height: 1.5;
      }

      .input:focus,
      .select:focus,
      .textarea:focus {
        border-color: var(--wood);
        box-shadow: 0 0 0 4px rgba(154, 101, 53, 0.12);
      }

      .photo-box {
        display: grid;
        gap: 0.8rem;
        padding: 1rem;
        border: 1px dashed var(--line-dark);
        border-radius: 24px;
        background: rgba(255, 250, 241, 0.42);
      }

      .photo-box p {
        margin: 0;
        color: var(--muted);
        line-height: 1.6;
      }

      .photo-list {
  display: grid;
  gap: 0.75rem;
}

.photo-list-text {
  color: var(--wood-dark);
  font-size: 0.9rem;
  font-weight: 850;
}

.photo-preview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}

.photo-preview-card {
  overflow: hidden;
  border-radius: 18px;
  border: 1px solid var(--line);
  background: rgba(255, 250, 241, 0.68);
}

.photo-preview-card img {
  display: block;
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
}

.photo-preview-card span {
  display: block;
  padding: 0.55rem;
  color: var(--muted);
  font-size: 0.74rem;
  font-weight: 800;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

      .checkbox-grid,
      .colour-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
      }

      .check-card,
      .colour-card {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        min-height: 54px;
        padding: 0.85rem;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: rgba(255, 250, 241, 0.5);
        cursor: pointer;
        font-weight: 850;
      }

      .check-card input,
      .colour-card input {
        width: 18px;
        height: 18px;
        accent-color: var(--wood);
      }

      .colour-card {
        align-items: flex-start;
      }

      .colour-card strong {
        display: block;
        line-height: 1.1;
      }

      .colour-card small {
        display: block;
        margin-top: 0.25rem;
        color: var(--muted);
        font-weight: 700;
        line-height: 1.35;
      }

      .swatch {
        width: 22px;
        height: 22px;
        flex: 0 0 22px;
        border-radius: 999px;
        border: 1px solid rgba(32, 26, 19, 0.24);
        margin-top: 0.1rem;
      }

      .swatch-white {
        background: #f7f4ea;
      }

      .swatch-grey {
        background: #b8b6ae;
      }

      .swatch-black {
        background: #171717;
      }

      .swatch-oak {
        background: #b9824b;
      }

      .swatch-gloss {
        background: linear-gradient(135deg, #ffffff, #d9d9d9, #ffffff);
      }

      .swatch-other {
        background: linear-gradient(135deg, #9a6535, #626a4f);
      }

      .estimate-preview-card {
        display: grid;
        align-content: space-between;
        gap: 1.2rem;
        padding: clamp(1rem, 3vw, 2rem);
        border-radius: 42px;
        background: var(--ink);
        color: var(--paper);
        box-shadow: var(--shadow);
      }

      .estimate-preview-card h3 {
        margin: 0;
        font-size: clamp(2.2rem, 4vw, 4.2rem);
        line-height: 0.88;
        letter-spacing: -0.08em;
      }

      .estimate-preview-card p {
        margin: 0;
        color: rgba(244, 239, 229, 0.68);
        line-height: 1.75;
      }

      .estimate-preview {
        min-height: 260px;
        white-space: pre-wrap;
        overflow-wrap: break-word;
        padding: 1rem;
        border-radius: 24px;
        background: rgba(255, 250, 241, 0.08);
        border: 1px solid rgba(255, 250, 241, 0.14);
        color: rgba(244, 239, 229, 0.88);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.86rem;
        line-height: 1.65;
      }

      .estimate-note {
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.7;
      }

      .quote-section {
        margin: 0 clamp(1rem, 4vw, 4.8rem) clamp(4.8rem, 8vw, 8rem);
        display: grid;
        grid-template-columns: 1fr 0.82fr;
        min-height: 640px;
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .quote-copy {
        display: grid;
        align-content: center;
        padding: clamp(2rem, 5vw, 5rem) 0;
      }

      .quote-copy h2 {
        margin: 0;
        max-width: 840px;
        font-size: clamp(3.6rem, 9vw, 9rem);
        line-height: 0.78;
        letter-spacing: -0.105em;
      }

      .quote-copy p {
        max-width: 660px;
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.9;
      }

      .contact-card {
        margin: clamp(2rem, 4vw, 4rem) 0 clamp(2rem, 4vw, 4rem) clamp(1rem, 4vw, 4rem);
        padding: 1.4rem;
        display: grid;
        align-content: space-between;
        background: var(--ink);
        color: var(--paper);
        border-radius: 48px;
        box-shadow: var(--shadow);
      }

      .contact-card h3 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 4rem);
        line-height: 0.88;
        letter-spacing: -0.08em;
      }

      .contact-card p {
        color: rgba(244, 239, 229, 0.68);
        line-height: 1.75;
      }

      .contact-actions {
        display: grid;
        gap: 0.8rem;
      }

      .contact-card .btn-light {
        background: var(--paper);
        color: var(--ink);
        border-color: var(--paper);
      }

      .footer {
        display: grid;
        grid-template-columns: 1.2fr 1fr 1fr;
        gap: 2rem;
        padding: clamp(2rem, 5vw, 4.8rem);
        border-top: 1px solid var(--line);
        color: var(--muted);
      }

      .footer strong {
        display: block;
        color: var(--ink);
        margin-bottom: 0.7rem;
      }

      .footer a,
      .footer button {
        display: block;
        width: fit-content;
        border: 0;
        padding: 0;
        margin-top: 0.35rem;
        background: transparent;
        color: var(--muted);
        cursor: pointer;
      }

      .toast {
        position: fixed;
        left: 50%;
        bottom: 2rem;
        z-index: 120;
        transform: translateX(-50%) translateY(18px);
        opacity: 0;
        pointer-events: none;
        max-width: calc(100vw - 2rem);
        padding: 0.9rem 1.1rem;
        border-radius: 999px;
        background: var(--ink);
        color: var(--paper);
        font-weight: 950;
        box-shadow: var(--shadow);
        transition: 0.25s ease;
      }

      .toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      .mobile-sticky {
        display: none;
      }

      @media (max-width: 1100px) {
        .hero,
        .feature,
        .quote-section,
        .menu-inner,
        .estimate-builder {
          grid-template-columns: 1fr;
        }

        .hero-gallery {
          grid-template-columns: 1fr;
        }

        .hero-image,
        .hero-image.small,
        .feature-image {
          min-height: 520px;
          border-radius: 42px;
        }

        .product-grid {
          grid-template-columns: 1fr;
        }

        .product-card {
          min-height: auto;
        }

        .contact-card {
          margin-left: 0;
        }

        .footer {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 720px) {
        .nav {
          grid-template-columns: auto 1fr auto;
          padding: 0.85rem 1rem;
        }

        .brand {
          justify-self: start;
        }

        .brand strong {
          font-size: 1.3rem;
        }

        .brand span,
        .nav-email,
        .menu-button > span:last-child {
          display: none;
        }

        .hero {
          padding: 6.4rem 1rem 2rem;
        }

        .hero h1 {
          font-size: clamp(4.1rem, 20vw, 6.5rem);
        }

        .hero-actions {
          display: grid;
        }

        .btn {
          width: 100%;
        }

        .section {
          padding: 4rem 1rem;
        }

        .section-title {
          grid-template-columns: 1fr;
        }

        .section-title h2,
        .feature-copy h2,
        .quote-copy h2 {
          font-size: clamp(3.4rem, 17vw, 5.8rem);
        }

        .intro-grid,
.service-list,
.estimate-grid,
.checkbox-grid,
.colour-grid {
  grid-template-columns: 1fr;
}

.photo-preview-grid {
  grid-template-columns: repeat(2, 1fr);
}

        .product-visual {
          min-height: 260px;
        }

        .quote-section {
          margin-inline: 1rem;
        }

        .menu-info {
          border-right: 0;
          border-bottom: 1px solid rgba(255, 250, 241, 0.14);
          gap: 2rem;
        }

        .menu-list {
          padding: 1.5rem;
        }

        .menu-list a {
          grid-template-columns: 46px 1fr;
        }

        .menu-list strong {
          font-size: clamp(2.4rem, 15vw, 4.6rem);
        }

        .mobile-sticky {
          position: fixed;
          left: 0.85rem;
          right: 0.85rem;
          bottom: 0.85rem;
          z-index: 60;
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 0.65rem;
          padding: 0.6rem;
          border-radius: 22px;
          background: rgba(244, 239, 229, 0.86);
          backdrop-filter: blur(18px);
          border: 1px solid var(--line);
          box-shadow: var(--shadow);
        }

        .mobile-sticky .btn {
          min-height: 44px;
          padding: 0.75rem 0.8rem;
          font-size: 0.84rem;
        }

        .footer {
          padding-bottom: 6.5rem;
        }
      }
    </style>
  </head>

  <body>
    <div class="site">
      <nav class="nav">
        <button class="menu-button" type="button" data-open-menu>
          <span class="menu-lines">
            <span></span>
            <span></span>
          </span>
          <span>Menu</span>
        </button>

        <a class="brand" href="/" aria-label="WhichwoodFitters home">
          <strong>Whichwood</strong>
          <span>Fitters</span>
        </a>

        <button class="nav-email" type="button" data-copy-email>
          {email}
        </button>
      </nav>

      <div class="menu-overlay" id="menuOverlay">
        <div class="menu-inner">
          <div class="menu-info">
            <button class="close-menu" type="button" data-close-menu>
              Close
            </button>

            <p>
              WhichwoodFitters designs and installs custom kitchens, cupboards,
              wardrobes, TV units, vanities and storage solutions made to fit
              your exact space.
            </p>

            <a class="btn btn-light" href={whatsappLink} target="_blank" rel="noopener noreferrer">
              WhatsApp {displayPhone}
            </a>
          </div>

          <div class="menu-list">
            <a href="#products" data-menu-link>
              <small>01</small>
              <strong>Products</strong>
            </a>

            <a href="/gallery" data-menu-link>
              <small>02</small>
              <strong>Gallery</strong>
            </a>

            <a href="#estimate" data-menu-link>
              <small>03</small>
              <strong>Estimate</strong>
            </a>

            <a href="#philosophy" data-menu-link>
              <small>04</small>
              <strong>Philosophy</strong>
            </a>

            <a href="#service" data-menu-link>
              <small>05</small>
              <strong>Service</strong>
            </a>

            <a href="#quote" data-menu-link>
              <small>06</small>
              <strong>Contact</strong>
            </a>
          </div>
        </div>
      </div>

      <main>
        <section class="hero">
          <div class="hero-copy">
            <span class="page-label">Custom Carpentry</span>

            <h1>
              Connected
              <span>with wood</span>
            </h1>

            <p class="hero-text">
              Custom kitchens, built-in cupboards, wardrobes, TV units and
              fitted storage — created around your home, your measurements and
              the way you use the space.
            </p>

            <div class="hero-actions">
              <a class="btn btn-dark" href={whatsappLink} target="_blank" rel="noopener noreferrer">
                WhatsApp for quote
              </a>

              <a class="btn btn-light" href="#estimate">
                Build estimate
              </a>

              <a class="btn btn-light" href="/gallery">
                View gallery
              </a>

              <button class="btn btn-light" type="button" data-copy-email>
                Copy email
              </button>
            </div>
          </div>

          <div class="hero-gallery">
            <div class="hero-image large" style={`background-image: url('/images/hero-main.jpg');`}>
              <div class="image-caption">
                <strong>Kitchens, cupboards & fitted interiors</strong>
                <span>Modern storage with a clean custom-made finish.</span>
              </div>
            </div>

            <div class="hero-image small" style={`background-image: url('/images/hero-small.jpg');`}>
              <div class="image-caption">
                <strong>Measured properly</strong>
                <span>Every wall, corner, plug and ceiling height matters.</span>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="philosophy">
          <div class="section-title">
            <small>Philosophy</small>
            <h2>Good carpentry begins before the first board is cut.</h2>
          </div>

          <div class="intro-grid">
            <p class="intro-quote">
              A fitted unit should feel like it was always meant to be there.
            </p>

            <p class="intro-text">
              WhichwoodFitters focuses on accurate measuring, practical layouts,
              honest material choices and clean installation. The goal is simple:
              more useful storage, better-looking rooms and work that fits the
              home properly.
            </p>
          </div>
        </section>

        <section class="section" id="products">
          <div class="section-title">
            <small>Products</small>
            <h2>Designed for spaces that need better storage.</h2>
          </div>

          <div class="product-grid">
            {products.map((product) => (
              <article class="product-card">
                <div class="product-visual" style={`background-image: url('${product.image}');`}></div>

                <div class="product-content">
                  <div class="product-no">{product.no}</div>
                  <h3>{product.title}</h3>
                  <h4>{product.subtitle}</h4>
                  <p>{product.text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="section" id="service">
          <div class="feature">
            <div class="feature-image" style={`background-image: url('/images/service.jpg');`}></div>

            <div class="feature-copy">
              <span class="page-label">Service</span>
              <h2>From idea to fitted result.</h2>

              <p>
                Send photos, rough measurements and the type of unit you want.
                The clearer the space and finish choice, the cleaner the quote
                and the fewer costly surprises later.
              </p>

              <div class="service-list">
                {services.map((service) => (
                  <div class="service-item">{service}</div>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section class="section estimate-section" id="estimate">
          <div class="section-title">
            <small>Fast Estimate</small>
            <h2>Send the right details for a faster quote.</h2>
          </div>

          <div class="estimate-builder">
            <form class="estimate-panel estimate-form" id="estimateForm">
              <div class="field">
                <label for="projectType">Project type</label>
                <select class="select" id="projectType">
                  <option value="Kitchen">Kitchen</option>
                  <option value="Built-in cupboards">Built-in cupboards</option>
                  <option value="Wardrobe">Wardrobe</option>
                  <option value="TV unit">TV unit</option>
                  <option value="Bathroom vanity">Bathroom vanity</option>
                  <option value="Storage solution">Storage solution</option>
                  <option value="Custom melamine work">Custom melamine work</option>
                </select>
              </div>

              <div class="photo-box">
                <div>
                  <div class="field-title">Photos</div>
                  <p>
                    Take or upload photos of the full wall, close-up corners,
                    plugs, pipes, ceiling and the area where the unit must fit.
                  </p>
                </div>

                <input
                  class="input"
                  id="estimatePhotos"
                  type="file"
                  accept="image/*"
                  capture="environment"
                  multiple
                />

                <div class="photo-list" id="selectedPhotos">
  <div class="photo-list-text">No photos selected yet.</div>
</div>

<p class="estimate-note">
  On mobile, the button will try to share the selected photos and message together.
  Choose WhatsApp when your phone asks where to share.
</p>
              </div>

              <div class="estimate-grid">
                <div class="field">
                  <label for="widthMeasure">Width</label>
                  <input class="input" id="widthMeasure" type="text" placeholder="Example: 3200mm" />
                </div>

                <div class="field">
                  <label for="heightMeasure">Height</label>
                  <input class="input" id="heightMeasure" type="text" placeholder="Example: 2400mm" />
                </div>

                <div class="field">
                  <label for="depthMeasure">Depth</label>
                  <input class="input" id="depthMeasure" type="text" placeholder="Example: 600mm" />
                </div>
              </div>

              <div class="field">
                <div class="field-title">What must we see in the photos?</div>

                <div class="checkbox-grid">
                  <label class="check-card">
                    <input type="checkbox" name="siteDetails" value="Plugs" />
                    Plugs
                  </label>

                  <label class="check-card">
                    <input type="checkbox" name="siteDetails" value="Pipes" />
                    Pipes
                  </label>

                  <label class="check-card">
                    <input type="checkbox" name="siteDetails" value="Corners" />
                    Corners
                  </label>

                  <label class="check-card">
                    <input type="checkbox" name="siteDetails" value="Ceiling height" />
                    Ceiling height
                  </label>

                  <label class="check-card">
                    <input type="checkbox" name="siteDetails" value="Skirting" />
                    Skirting
                  </label>

                  <label class="check-card">
                    <input type="checkbox" name="siteDetails" value="Uneven wall or floor" />
                    Uneven wall/floor
                  </label>
                </div>
              </div>

              <div class="field">
                <div class="field-title">Colour / finish option</div>

                <div class="colour-grid">
                  <label class="colour-card">
                    <input type="radio" name="finishOption" value="White melamine" checked />
                    <span class="swatch swatch-white"></span>
                    <span>
                      <strong>White</strong>
                      <small>Clean, bright, modern</small>
                    </span>
                  </label>

                  <label class="colour-card">
                    <input type="radio" name="finishOption" value="Light grey melamine" />
                    <span class="swatch swatch-grey"></span>
                    <span>
                      <strong>Light Grey</strong>
                      <small>Soft neutral finish</small>
                    </span>
                  </label>

                  <label class="colour-card">
                    <input type="radio" name="finishOption" value="Black melamine" />
                    <span class="swatch swatch-black"></span>
                    <span>
                      <strong>Black</strong>
                      <small>Bold premium look</small>
                    </span>
                  </label>

                  <label class="colour-card">
                    <input type="radio" name="finishOption" value="Oak / wood-look melamine" />
                    <span class="swatch swatch-oak"></span>
                    <span>
                      <strong>Oak / Wood Look</strong>
                      <small>Warm natural style</small>
                    </span>
                  </label>

                  <label class="colour-card">
                    <input type="radio" name="finishOption" value="SupaGloss / high-gloss finish" />
                    <span class="swatch swatch-gloss"></span>
                    <span>
                      <strong>SupaGloss</strong>
                      <small>Gloss modern finish</small>
                    </span>
                  </label>

                  <label class="colour-card">
                    <input type="radio" name="finishOption" value="Other finish / not sure yet" />
                    <span class="swatch swatch-other"></span>
                    <span>
                      <strong>Other</strong>
                      <small>Need advice</small>
                    </span>
                  </label>
                </div>
              </div>

              <div class="field">
                <label for="estimateNotes">Extra notes</label>
                <textarea
                  class="textarea"
                  id="estimateNotes"
                  placeholder="Example: Need drawers, hanging space, shelves, soft-close hinges, LED lighting, or matching existing cupboards."
                ></textarea>
              </div>
            </form>

            <div class="estimate-preview-card">
              <div>
                <h3>Your WhatsApp request.</h3>
                <p>
                  This message updates as the client fills in the form. When they click
                  the button, WhatsApp opens with the quote details ready.
                </p>
              </div>

              <pre class="estimate-preview" id="estimatePreview"></pre>

              <button class="btn btn-light" id="estimateWhatsAppButton" type="button">
  Share Photos + Estimate to WhatsApp
</button>

              <p>
  Best on mobile. The site will try to share the selected photos with the estimate message.
  If the browser blocks file sharing, WhatsApp will open with the message only.
</p>
            </div>
          </div>
        </section>

        <section class="quote-section" id="quote">
          <div class="quote-copy">
            <span class="page-label">Personal Quote</span>
            <h2>Send your space.</h2>

            <p>
              WhatsApp is the fastest way. Send photos, rough measurements,
              finish ideas and your location. You can also copy the email
              address or open your email app.
            </p>
          </div>

          <div class="contact-card">
            <div>
              <h3>WhichwoodFitters</h3>
              <p>
                Custom kitchens, built-in cupboards, wardrobes, TV units,
                vanities and fitted storage.
              </p>
            </div>

            <div class="contact-actions">
              <a class="btn btn-light" href={whatsappLink} target="_blank" rel="noopener noreferrer">
                WhatsApp {displayPhone}
              </a>

              <a class="btn btn-outline-light" href="#estimate">
                Build estimate
              </a>

              <a class="btn btn-outline-light" href="/gallery">
                View gallery
              </a>

              <button class="btn btn-outline-light" type="button" data-copy-email>
                Copy {email}
              </button>

              <a class="btn btn-outline-light" href={mailLink}>
                Open email app
              </a>
            </div>
          </div>
        </section>
      </main>

      <footer class="footer">
        <div>
          <strong>WhichwoodFitters</strong>
          <span>Custom carpentry and fitted storage.</span>
        </div>

        <div>
          <strong>Contact</strong>
          <a href={whatsappLink} target="_blank" rel="noopener noreferrer">
            WhatsApp {displayPhone}
          </a>
          <button type="button" data-copy-email>{email}</button>
        </div>

        <div>
          <strong>Pages</strong>
          <a href="/">Home</a>
          <a href="/gallery">Gallery</a>
          <a href="#estimate">Fast Estimate</a>
        </div>
      </footer>

      <div class="mobile-sticky">
        <a class="btn btn-light" href="#estimate">
          Estimate
        </a>

        <a class="btn btn-dark" href={whatsappLink} target="_blank" rel="noopener noreferrer">
          WhatsApp
        </a>
      </div>

      <div class="toast" id="emailToast" role="status" aria-live="polite">
        Email copied: {email}
      </div>
    </div>

    <script define:vars={{ email, mailLink, whatsappNumber }}>
      const openMenuButton = document.querySelector("[data-open-menu]");
      const closeMenuButton = document.querySelector("[data-close-menu]");
      const menuOverlay = document.getElementById("menuOverlay");
      const menuLinks = document.querySelectorAll("[data-menu-link]");
      const copyButtons = document.querySelectorAll("[data-copy-email]");
      const toast = document.getElementById("emailToast");

      const estimateForm = document.getElementById("estimateForm");
      const estimatePhotos = document.getElementById("estimatePhotos");
      const selectedPhotos = document.getElementById("selectedPhotos");
      const estimatePreview = document.getElementById("estimatePreview");
      const estimateWhatsAppButton = document.getElementById("estimateWhatsAppButton");

      function openMenu() {
        if (!menuOverlay) return;
        menuOverlay.classList.add("open");
        document.body.style.overflow = "hidden";
      }

      function closeMenu() {
        if (!menuOverlay) return;
        menuOverlay.classList.remove("open");
        document.body.style.overflow = "";
      }

      function showToast(message) {
        if (!toast) return;

        toast.textContent = message;
        toast.classList.add("show");

        window.setTimeout(() => {
          toast.classList.remove("show");
        }, 2400);
      }

      function fallbackCopy(text) {
        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        textarea.style.top = "0";

        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();

        const successful = document.execCommand("copy");
        document.body.removeChild(textarea);

        return successful;
      }

      async function copyEmail() {
        try {
          if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText(email);
          } else {
            const copied = fallbackCopy(email);

            if (!copied) {
              throw new Error("Fallback copy failed.");
            }
          }

          showToast(`Email copied: ${email}`);
        } catch {
          showToast(`Email: ${email}`);

          window.setTimeout(() => {
            window.location.href = mailLink;
          }, 900);
        }
      }

      function getInputValue(id) {
        const element = document.getElementById(id);
        const value = element?.value?.trim();

        return value && value.length > 0 ? value : "Not supplied";
      }

      function getCheckedValues(name) {
        const checked = Array.from(document.querySelectorAll(`input[name="${name}"]:checked`))
          .map((input) => input.value);

        return checked.length > 0 ? checked.join(", ") : "Not supplied";
      }

      function getSelectedFinish() {
        const selected = document.querySelector('input[name="finishOption"]:checked');
        return selected?.value || "Not supplied";
      }

      let activePhotoUrls = [];

function getSelectedPhotoFiles() {
  return Array.from(estimatePhotos?.files || []);
}

function getSelectedPhotoNames() {
  return getSelectedPhotoFiles().map((file) => file.name);
}

function clearPhotoUrls() {
  activePhotoUrls.forEach((url) => URL.revokeObjectURL(url));
  activePhotoUrls = [];
}

function updateSelectedPhotos() {
  if (!selectedPhotos) return;

  clearPhotoUrls();

  const files = getSelectedPhotoFiles();
  selectedPhotos.replaceChildren();

  if (files.length === 0) {
    const emptyText = document.createElement("div");
    emptyText.className = "photo-list-text";
    emptyText.textContent = "No photos selected yet.";
    selectedPhotos.appendChild(emptyText);
    return;
  }

  const countText = document.createElement("div");
  countText.className = "photo-list-text";
  countText.textContent = `${files.length} photo(s) selected and ready to share.`;
  selectedPhotos.appendChild(countText);

  const previewGrid = document.createElement("div");
  previewGrid.className = "photo-preview-grid";

  files.forEach((file, index) => {
    const imageUrl = URL.createObjectURL(file);
    activePhotoUrls.push(imageUrl);

    const card = document.createElement("div");
    card.className = "photo-preview-card";

    const image = document.createElement("img");
    image.src = imageUrl;
    image.alt = `Selected estimate photo ${index + 1}`;

    const label = document.createElement("span");
    label.textContent = `${index + 1}. ${file.name}`;

    card.appendChild(image);
    card.appendChild(label);
    previewGrid.appendChild(card);
  });

  selectedPhotos.appendChild(previewGrid);
}
      }

      function buildEstimateMessage() {
        const projectType = getInputValue("projectType");
        const width = getInputValue("widthMeasure");
        const height = getInputValue("heightMeasure");
        const depth = getInputValue("depthMeasure");
        const visibleDetails = getCheckedValues("siteDetails");
        const finish = getSelectedFinish();
        const notes = getInputValue("estimateNotes");
        const photos = getSelectedPhotoNames();

        const photoText =
          photos.length > 0
            ? `${photos.length} photo(s) selected. I will attach them in WhatsApp.`
            : "No photos selected yet. I still need to attach photos.";

        const message =
`Hi WhichwoodFitters, I need a fast estimate.

Project type: ${projectType}

Measurements:
Width: ${width}
Height: ${height}
Depth: ${depth}

Photos:
${photoText}

Please check these in the photos:
${visibleDetails}

Colour / finish:
${finish}

Extra notes:
${notes}

Please let me know what else you need for the quote.`;

        if (estimatePreview) {
          estimatePreview.textContent = message;
        }

        return message;
      }

      async function openEstimateWhatsApp() {
  const message = buildEstimateMessage();
  const files = getSelectedPhotoFiles();

  try {
    if (
      files.length > 0 &&
      navigator.canShare &&
      navigator.share &&
      navigator.canShare({ files })
    ) {
      await navigator.share({
        title: "WhichwoodFitters Estimate Request",
        text: message,
        files
      });

      showToast("Photos and estimate shared. Choose WhatsApp if asked.");
      return;
    }
  } catch {
    showToast("Photo sharing was cancelled or blocked.");
  }

  const link = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`;
  window.open(link, "_blank", "noopener,noreferrer");

  if (files.length > 0) {
    showToast("WhatsApp opened with text. Attach the selected photos manually if they did not share.");
  } else {
    showToast("WhatsApp estimate request opened.");
  }
}

      openMenuButton?.addEventListener("click", openMenu);
      closeMenuButton?.addEventListener("click", closeMenu);

      menuLinks.forEach((link) => {
        link.addEventListener("click", closeMenu);
      });

      copyButtons.forEach((button) => {
        button.addEventListener("click", copyEmail);
      });

      estimatePhotos?.addEventListener("change", () => {
        updateSelectedPhotos();
        buildEstimateMessage();
      });

      estimateForm?.addEventListener("input", buildEstimateMessage);
      estimateForm?.addEventListener("change", buildEstimateMessage);

      estimateWhatsAppButton?.addEventListener("click", openEstimateWhatsApp);

      buildEstimateMessage();

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeMenu();
        }
      });
    </script>
  </body>
</html>
