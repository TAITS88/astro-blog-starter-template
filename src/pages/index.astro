---
const email = "ruhantait@yahoo.com";
const displayPhone = "079 910 1465";
const whatsappNumber = "27799101465";

const whatsappMessage = encodeURIComponent(
  "Hi WhichwoodFitters, I would like a quote for custom carpentry. I can send photos and measurements."
);

const whatsappLink = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;

const emailSubject = "Quote request - WhichwoodFitters";

const emailBody =
  "Hi WhichwoodFitters,\n\nI would like a quote for custom carpentry.\n\nProject type:\nMeasurements:\nPhotos attached:\nLocation:\n\nThank you.";

const mailLink = `mailto:${email}?subject=${encodeURIComponent(emailSubject)}&body=${encodeURIComponent(emailBody)}`;

const services = [
  {
    title: "Custom Kitchens",
    text: "Modern fitted kitchens designed around your space, appliances, workflow, and storage needs.",
    tag: "Kitchen"
  },
  {
    title: "Built-In Cupboards",
    text: "Bedroom cupboards, linen cupboards, wardrobes, and storage designed to fit wall-to-wall.",
    tag: "Cupboards"
  },
  {
    title: "TV Units",
    text: "Floating TV units, display shelves, feature walls, and clean cable-friendly entertainment storage.",
    tag: "Living"
  },
  {
    title: "Vanities",
    text: "Bathroom vanities and compact storage built for practical daily use with a clean premium finish.",
    tag: "Bathroom"
  },
  {
    title: "Storage Solutions",
    text: "Garage, laundry, office, pantry, and under-stair storage that turns dead space into useful space.",
    tag: "Storage"
  },
  {
    title: "Custom Fit-Outs",
    text: "Purpose-built units for awkward spaces, renovations, rentals, and homes needing smarter storage.",
    tag: "Custom"
  }
];

const steps = [
  "Send photos",
  "Send measurements",
  "Choose finish",
  "Approve quote",
  "Build and fit"
];

const finishes = [
  "White melamine",
  "Nordic / Iceberg white",
  "Woodgrain melamine",
  "Black accents",
  "Soft-close hinges",
  "Modern handles",
  "Push-to-open doors",
  "Quartz-ready kitchens"
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>WhichwoodFitters | Modern Custom Carpentry & Built-In Cupboards</title>

    <meta
      name="description"
      content="WhichwoodFitters builds custom kitchens, built-in cupboards, wardrobes, TV units, vanities, and modern storage solutions."
    />

    <style>
      :root {
        --bg: #070604;
        --bg-2: #0d0a06;
        --text: #fff8ed;
        --muted: #c8b9a2;
        --soft: rgba(255, 248, 237, 0.72);
        --gold: #d9a44c;
        --gold-2: #ffe0a3;
        --wood: #8d5524;
        --brown: #2a190d;
        --glass: rgba(255, 255, 255, 0.075);
        --glass-strong: rgba(255, 255, 255, 0.12);
        --line: rgba(255, 255, 255, 0.13);
        --line-strong: rgba(255, 255, 255, 0.22);
        --shadow: 0 30px 100px rgba(0, 0, 0, 0.45);
        --radius-xl: 34px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--text);
        background:
          radial-gradient(circle at 12% 8%, rgba(217, 164, 76, 0.22), transparent 29rem),
          radial-gradient(circle at 88% 4%, rgba(255, 224, 163, 0.12), transparent 25rem),
          radial-gradient(circle at 72% 82%, rgba(141, 85, 36, 0.22), transparent 34rem),
          linear-gradient(135deg, var(--bg), var(--bg-2));
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.35;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
        background-size: 72px 72px;
        mask-image: radial-gradient(circle at center, black, transparent 75%);
      }

      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background:
          linear-gradient(90deg, rgba(255,255,255,0.025), transparent 18%, transparent 82%, rgba(255,255,255,0.025)),
          radial-gradient(circle at center, transparent 45%, rgba(0,0,0,0.52));
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      button,
      a {
        -webkit-tap-highlight-color: transparent;
      }

      .site {
        position: relative;
        z-index: 1;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem clamp(1rem, 4vw, 4.5rem);
        background: rgba(7, 6, 4, 0.68);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(22px);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
      }

      .brand-mark {
        width: 48px;
        height: 48px;
        border-radius: 17px;
        display: grid;
        place-items: center;
        color: #130c05;
        font-weight: 1000;
        letter-spacing: -0.08em;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.42), transparent 38%),
          linear-gradient(135deg, var(--gold-2), var(--gold), var(--wood));
        box-shadow:
          0 18px 55px rgba(217, 164, 76, 0.25),
          inset 0 1px 0 rgba(255, 255, 255, 0.55);
      }

      .brand-text {
        display: grid;
        line-height: 1;
      }

      .brand-text strong {
        font-size: clamp(1.05rem, 2vw, 1.35rem);
        letter-spacing: -0.055em;
      }

      .brand-text span {
        margin-top: 0.25rem;
        color: var(--muted);
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 1.3rem;
        color: var(--muted);
        font-size: 0.93rem;
        font-weight: 650;
      }

      .nav-links a {
        position: relative;
      }

      .nav-links a::after {
        content: "";
        position: absolute;
        left: 0;
        right: 100%;
        bottom: -0.4rem;
        height: 1px;
        background: var(--gold-2);
        transition: right 0.22s ease;
      }

      .nav-links a:hover {
        color: var(--text);
      }

      .nav-links a:hover::after {
        right: 0;
      }

      .nav-actions {
        display: flex;
        align-items: center;
        gap: 0.7rem;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        min-height: 46px;
        padding: 0.88rem 1.15rem;
        border-radius: 999px;
        border: 1px solid transparent;
        font-size: 0.94rem;
        font-weight: 850;
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease,
          border-color 0.2s ease,
          background 0.2s ease;
        white-space: nowrap;
        cursor: pointer;
      }

      .btn:hover {
        transform: translateY(-2px);
      }

      .btn-primary {
        color: #140c04;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.48), transparent 36%),
          linear-gradient(135deg, var(--gold-2), var(--gold));
        box-shadow: 0 18px 55px rgba(217, 164, 76, 0.24);
      }

      .btn-primary:hover {
        box-shadow: 0 24px 72px rgba(217, 164, 76, 0.34);
      }

      .btn-ghost {
        color: var(--text);
        background: rgba(255, 255, 255, 0.075);
        border-color: var(--line);
      }

      .btn-ghost:hover {
        background: rgba(255, 255, 255, 0.115);
        border-color: var(--line-strong);
      }

      .hero {
        min-height: calc(100vh - 82px);
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(350px, 0.95fr);
        align-items: center;
        gap: clamp(2rem, 5vw, 5.5rem);
        padding: clamp(3rem, 7vw, 7rem) clamp(1rem, 4vw, 4.5rem);
      }

      .status-pill {
        width: fit-content;
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        margin-bottom: 1.35rem;
        padding: 0.56rem 0.85rem;
        border-radius: 999px;
        color: #ffe6b4;
        font-size: 0.88rem;
        font-weight: 800;
        background: rgba(217, 164, 76, 0.11);
        border: 1px solid rgba(217, 164, 76, 0.32);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
      }

      .pulse {
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: #9dffad;
        box-shadow: 0 0 0 7px rgba(157, 255, 173, 0.09);
      }

      .hero h1 {
        margin: 0;
        max-width: 980px;
        font-size: clamp(3.4rem, 8.6vw, 8.2rem);
        line-height: 0.84;
        letter-spacing: -0.085em;
      }

      .gradient-text {
        background: linear-gradient(135deg, #fff8ed, #ffe0a3 38%, #d9a44c 75%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      .hero-lead {
        max-width: 720px;
        margin: 1.45rem 0 0;
        color: var(--soft);
        font-size: clamp(1.05rem, 1.8vw, 1.32rem);
        line-height: 1.75;
      }

      .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 2rem;
      }

      .contact-strip {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem;
        max-width: 760px;
        margin-top: 1.25rem;
      }

      .contact-chip {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        min-height: 76px;
        width: 100%;
        padding: 1rem;
        border-radius: 24px;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.045)),
          rgba(255, 255, 255, 0.055);
        border: 1px solid var(--line);
        box-shadow: 0 18px 55px rgba(0, 0, 0, 0.18);
        color: var(--text);
        text-align: left;
        cursor: pointer;
      }

      .contact-chip small {
        display: block;
        color: var(--muted);
        font-size: 0.78rem;
        margin-bottom: 0.28rem;
      }

      .contact-chip strong {
        display: block;
        font-size: clamp(0.95rem, 1.5vw, 1.05rem);
        letter-spacing: -0.02em;
      }

      .arrow-icon {
        width: 42px;
        height: 34px;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
        border-radius: 999px;
        color: #130c05;
        background: linear-gradient(135deg, var(--gold-2), var(--gold));
        font-size: 0.78rem;
        font-weight: 900;
      }

      .hero-panel-wrap {
        position: relative;
      }

      .hero-panel-wrap::before {
        content: "";
        position: absolute;
        inset: -2rem;
        border-radius: 60px;
        background: radial-gradient(circle, rgba(217, 164, 76, 0.26), transparent 64%);
        filter: blur(10px);
        animation: glowFloat 7s ease-in-out infinite;
      }

      .hero-panel {
        position: relative;
        min-height: 610px;
        padding: 1rem;
        border-radius: 42px;
        overflow: hidden;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.16), transparent 32%),
          rgba(255, 255, 255, 0.065);
        border: 1px solid var(--line-strong);
        box-shadow: var(--shadow);
      }

      .cabinet-visual {
        position: relative;
        min-height: 580px;
        height: 100%;
        border-radius: 34px;
        overflow: hidden;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.12), transparent 40%),
          linear-gradient(160deg, #2a190d, #0d0a06 64%);
      }

      .cabinet-visual::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(90deg, transparent 0 8%, rgba(255,255,255,0.09) 8% 8.4%, transparent 8.4% 100%),
          linear-gradient(0deg, rgba(255,255,255,0.08) 0 1px, transparent 1px 100%);
        background-size: 100% 100%, 100% 82px;
        opacity: 0.64;
      }

      .cabinet-visual::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 25% 18%, rgba(255,255,255,0.2), transparent 18rem),
          linear-gradient(180deg, transparent, rgba(0,0,0,0.5));
      }

      .wood-slab {
        position: absolute;
        border-radius: 24px;
        overflow: hidden;
        background:
          linear-gradient(90deg, rgba(255,255,255,0.12), transparent 28%),
          repeating-linear-gradient(
            90deg,
            #6f411d 0,
            #6f411d 17px,
            #8d5524 17px,
            #8d5524 36px,
            #a96c2f 36px,
            #a96c2f 56px
          );
        box-shadow:
          0 26px 65px rgba(0, 0, 0, 0.34),
          inset 0 1px 0 rgba(255, 255, 255, 0.18);
      }

      .slab-one {
        top: 7%;
        left: 8%;
        width: 38%;
        height: 52%;
        transform: rotate(-2deg);
      }

      .slab-two {
        top: 14%;
        right: 8%;
        width: 38%;
        height: 66%;
        transform: rotate(2deg);
        background:
          linear-gradient(90deg, rgba(255,255,255,0.11), transparent 32%),
          repeating-linear-gradient(
            90deg,
            #e9e1d4 0,
            #e9e1d4 20px,
            #fff8ed 20px,
            #fff8ed 42px
          );
      }

      .slab-three {
        bottom: 7%;
        left: 10%;
        width: 80%;
        height: 22%;
      }

      .floating-card {
        position: absolute;
        left: 7%;
        right: 7%;
        bottom: 7%;
        z-index: 2;
        display: grid;
        gap: 0.95rem;
        padding: 1.15rem;
        border-radius: 28px;
        border: 1px solid rgba(255, 255, 255, 0.16);
        background: rgba(8, 7, 5, 0.72);
        backdrop-filter: blur(20px);
        box-shadow: 0 28px 70px rgba(0, 0, 0, 0.34);
      }

      .floating-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .floating-card h2 {
        margin: 0;
        font-size: 1.25rem;
        letter-spacing: -0.035em;
      }

      .floating-card p {
        margin: 0.38rem 0 0;
        color: var(--muted);
        line-height: 1.6;
        font-size: 0.95rem;
      }

      .mini-badge {
        flex: 0 0 auto;
        padding: 0.48rem 0.7rem;
        border-radius: 999px;
        color: #160f07;
        background: linear-gradient(135deg, var(--gold-2), var(--gold));
        font-size: 0.78rem;
        font-weight: 900;
      }

      .mini-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.6rem;
      }

      .mini-stat {
        padding: 0.85rem;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.075);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .mini-stat strong {
        display: block;
        font-size: 1rem;
      }

      .mini-stat span {
        display: block;
        margin-top: 0.18rem;
        color: var(--muted);
        font-size: 0.76rem;
      }

      .marquee {
        border-block: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.035);
        overflow: hidden;
      }

      .marquee-track {
        display: flex;
        width: max-content;
        animation: marquee 28s linear infinite;
      }

      .marquee-track span {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        padding: 1rem 1.7rem;
        color: var(--muted);
        font-weight: 800;
        letter-spacing: 0.02em;
        white-space: nowrap;
      }

      .marquee-track span::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--gold);
        box-shadow: 0 0 22px rgba(217, 164, 76, 0.8);
      }

      .section {
        padding: clamp(4.5rem, 8vw, 7.5rem) clamp(1rem, 4vw, 4.5rem);
      }

      .section-head {
        display: grid;
        grid-template-columns: 0.9fr 1fr;
        gap: 2rem;
        align-items: end;
        margin-bottom: 2rem;
      }

      .section-kicker {
        width: fit-content;
        display: inline-flex;
        margin-bottom: 1rem;
        padding: 0.48rem 0.72rem;
        border-radius: 999px;
        color: #ffe6b4;
        background: rgba(217, 164, 76, 0.1);
        border: 1px solid rgba(217, 164, 76, 0.25);
        font-size: 0.8rem;
        font-weight: 850;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .section h2 {
        margin: 0;
        max-width: 840px;
        font-size: clamp(2.45rem, 5.4vw, 5.2rem);
        line-height: 0.9;
        letter-spacing: -0.075em;
      }

      .section-head p {
        margin: 0;
        max-width: 760px;
        color: var(--muted);
        font-size: clamp(1rem, 1.4vw, 1.12rem);
        line-height: 1.8;
      }

      .bento {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 1rem;
      }

      .bento-card {
        position: relative;
        min-height: 250px;
        grid-column: span 2;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 1.35rem;
        border-radius: var(--radius-xl);
        overflow: hidden;
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.115), rgba(255, 255, 255, 0.04)),
          rgba(255, 255, 255, 0.055);
        border: 1px solid var(--line);
        box-shadow: 0 26px 80px rgba(0, 0, 0, 0.22);
        opacity: 0;
        transform: translateY(22px);
        animation: reveal 0.7s ease forwards;
        animation-delay: var(--delay);
      }

      .bento-card:nth-child(1),
      .bento-card:nth-child(6) {
        grid-column: span 3;
      }

      .bento-card::before {
        content: "";
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.25s ease;
        background:
          radial-gradient(circle at 15% 10%, rgba(255, 224, 163, 0.18), transparent 18rem),
          radial-gradient(circle at 95% 85%, rgba(217, 164, 76, 0.16), transparent 16rem);
      }

      .bento-card:hover::before {
        opacity: 1;
      }

      .card-content {
        position: relative;
        z-index: 1;
      }

      .tag {
        display: inline-flex;
        width: fit-content;
        margin-bottom: 1.2rem;
        padding: 0.45rem 0.68rem;
        border-radius: 999px;
        color: #ffe8bb;
        background: rgba(217, 164, 76, 0.1);
        border: 1px solid rgba(217, 164, 76, 0.25);
        font-size: 0.78rem;
        font-weight: 850;
      }

      .bento-card h3 {
        margin: 0;
        font-size: clamp(1.45rem, 2.3vw, 2rem);
        line-height: 1;
        letter-spacing: -0.055em;
      }

      .bento-card p {
        position: relative;
        z-index: 1;
        margin: 1rem 0 0;
        color: var(--muted);
        line-height: 1.7;
      }

      .card-line {
        position: relative;
        z-index: 1;
        height: 1px;
        width: 100%;
        margin-top: 1.5rem;
        background: linear-gradient(90deg, var(--gold), transparent);
        opacity: 0.55;
      }

      .process-wrap {
        display: grid;
        grid-template-columns: 0.8fr 1.2fr;
        gap: 1rem;
        align-items: stretch;
      }

      .process-panel {
        min-height: 540px;
        border-radius: var(--radius-xl);
        padding: 1.3rem;
        background:
          linear-gradient(135deg, rgba(217, 164, 76, 0.16), transparent),
          rgba(255, 255, 255, 0.055);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .process-art {
        position: relative;
        height: 100%;
        min-height: 510px;
        border-radius: 28px;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.11), transparent 32%),
          repeating-linear-gradient(
            90deg,
            #6d401e 0,
            #6d401e 22px,
            #875225 22px,
            #875225 48px,
            #a0692f 48px,
            #a0692f 72px
          );
        overflow: hidden;
      }

      .process-art::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 25% 22%, rgba(255, 255, 255, 0.2), transparent 15rem),
          linear-gradient(180deg, transparent, rgba(0,0,0,0.58));
      }

      .process-art-card {
        position: absolute;
        left: 1rem;
        right: 1rem;
        bottom: 1rem;
        padding: 1rem;
        border-radius: 22px;
        background: rgba(7, 6, 4, 0.72);
        border: 1px solid rgba(255, 255, 255, 0.13);
        backdrop-filter: blur(18px);
      }

      .process-art-card strong {
        display: block;
        font-size: 1.1rem;
      }

      .process-art-card span {
        display: block;
        margin-top: 0.4rem;
        color: var(--muted);
        line-height: 1.55;
      }

      .steps {
        display: grid;
        gap: 0.8rem;
      }

      .step {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1rem;
        align-items: center;
        padding: 1.1rem;
        border-radius: 26px;
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.035)),
          rgba(255, 255, 255, 0.055);
        border: 1px solid var(--line);
      }

      .step-number {
        width: 52px;
        height: 52px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        color: #160f07;
        font-weight: 950;
        background:
          linear-gradient(135deg, rgba(255,255,255,0.45), transparent 38%),
          linear-gradient(135deg, var(--gold-2), var(--gold));
      }

      .step h3 {
        margin: 0;
        font-size: 1.22rem;
        letter-spacing: -0.035em;
      }

      .step p {
        margin: 0.32rem 0 0;
        color: var(--muted);
        line-height: 1.55;
      }

      .finish-lab {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      .finish-card {
        min-height: 520px;
        border-radius: var(--radius-xl);
        padding: 1.35rem;
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04)),
          rgba(255, 255, 255, 0.055);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
      }

      .sample-wall {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.8rem;
      }

      .sample {
        min-height: 155px;
        border-radius: 24px;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.14);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
      }

      .sample::after {
        content: attr(data-name);
        position: absolute;
        left: 0.8rem;
        right: 0.8rem;
        bottom: 0.8rem;
        padding: 0.55rem 0.7rem;
        border-radius: 999px;
        color: var(--text);
        font-size: 0.8rem;
        font-weight: 850;
        background: rgba(7, 6, 4, 0.58);
        backdrop-filter: blur(12px);
      }

      .sample-white {
        background:
          linear-gradient(135deg, rgba(255,255,255,0.8), transparent 50%),
          repeating-linear-gradient(90deg, #e9e6dd 0, #e9e6dd 20px, #fbf8ef 20px, #fbf8ef 44px);
      }

      .sample-wood {
        background:
          linear-gradient(90deg, rgba(255,255,255,0.12), transparent 32%),
          repeating-linear-gradient(90deg, #6f411d 0, #6f411d 17px, #8d5524 17px, #8d5524 36px, #a96c2f 36px, #a96c2f 56px);
      }

      .sample-black {
        background:
          radial-gradient(circle at 25% 18%, rgba(255,255,255,0.18), transparent 11rem),
          linear-gradient(135deg, #2c2924, #090807);
      }

      .sample-stone {
        background:
          linear-gradient(135deg, rgba(255,255,255,0.42), transparent 32%),
          linear-gradient(160deg, #c7b8a1, #f4eadc);
      }

      .finish-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
        margin-top: 1.4rem;
      }

      .finish-pill {
        padding: 0.72rem 0.9rem;
        border-radius: 999px;
        color: var(--soft);
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.12);
        font-weight: 750;
      }

      .quote-section {
        padding: 0 clamp(1rem, 4vw, 4.5rem) clamp(4.5rem, 8vw, 7.5rem);
      }

      .quote-box {
        position: relative;
        overflow: hidden;
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        gap: 2rem;
        padding: clamp(1.45rem, 4vw, 3rem);
        border-radius: 38px;
        background:
          radial-gradient(circle at 10% 10%, rgba(255, 224, 163, 0.18), transparent 22rem),
          linear-gradient(135deg, rgba(217, 164, 76, 0.18), rgba(255, 255, 255, 0.055)),
          rgba(255, 255, 255, 0.07);
        border: 1px solid var(--line-strong);
        box-shadow: var(--shadow);
      }

      .quote-box h2 {
        margin: 0;
        max-width: 820px;
        font-size: clamp(2.35rem, 5vw, 5rem);
        line-height: 0.9;
        letter-spacing: -0.075em;
      }

      .quote-box p {
        max-width: 750px;
        margin: 1rem 0 0;
        color: var(--muted);
        line-height: 1.75;
        font-size: 1.06rem;
      }

      .quote-actions {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        min-width: 260px;
      }

      .footer {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        padding: 2rem clamp(1rem, 4vw, 4.5rem);
        color: var(--muted);
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(0, 0, 0, 0.14);
      }

      .toast {
        position: fixed;
        left: 50%;
        bottom: 6.8rem;
        z-index: 100;
        transform: translateX(-50%) translateY(18px);
        opacity: 0;
        pointer-events: none;
        width: max-content;
        max-width: calc(100vw - 2rem);
        padding: 0.9rem 1.15rem;
        border-radius: 999px;
        color: #140c04;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.45), transparent 35%),
          linear-gradient(135deg, var(--gold-2), var(--gold));
        font-weight: 950;
        box-shadow: 0 22px 70px rgba(0, 0, 0, 0.38);
        transition: 0.25s ease;
      }

      .toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      .mobile-sticky {
        display: none;
      }

      @keyframes reveal {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes marquee {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }

      @keyframes glowFloat {
        0%,
        100% {
          transform: translateY(0) scale(1);
          opacity: 0.76;
        }
        50% {
          transform: translateY(-12px) scale(1.03);
          opacity: 1;
        }
      }

      @media (max-width: 1120px) {
        .hero,
        .process-wrap,
        .finish-lab {
          grid-template-columns: 1fr;
        }

        .hero-panel {
          min-height: 520px;
        }

        .cabinet-visual {
          min-height: 490px;
        }

        .section-head {
          grid-template-columns: 1fr;
          align-items: start;
        }

        .bento-card,
        .bento-card:nth-child(1),
        .bento-card:nth-child(6) {
          grid-column: span 3;
        }

        .quote-box {
          grid-template-columns: 1fr;
        }

        .quote-actions {
          flex-direction: row;
          flex-wrap: wrap;
          min-width: 0;
        }
      }

      @media (max-width: 760px) {
        .nav {
          align-items: flex-start;
          flex-direction: column;
        }

        .nav-links {
          display: none;
        }

        .nav-actions {
          width: 100%;
        }

        .nav-actions .btn {
          flex: 1;
        }

        .hero {
          min-height: auto;
          padding-top: 2.5rem;
        }

        .hero h1 {
          font-size: clamp(3rem, 15vw, 5.2rem);
        }

        .hero-ctas,
        .contact-strip,
        .mini-grid,
        .sample-wall {
          grid-template-columns: 1fr;
        }

        .hero-ctas {
          display: grid;
        }

        .contact-strip {
          display: grid;
        }

        .hero-panel {
          min-height: 470px;
          border-radius: 32px;
        }

        .cabinet-visual {
          min-height: 440px;
          border-radius: 26px;
        }

        .floating-card {
          left: 1rem;
          right: 1rem;
          bottom: 1rem;
        }

        .floating-top {
          align-items: flex-start;
          flex-direction: column;
        }

        .bento {
          grid-template-columns: 1fr;
        }

        .bento-card,
        .bento-card:nth-child(1),
        .bento-card:nth-child(6) {
          grid-column: span 1;
        }

        .step {
          grid-template-columns: 1fr;
        }

        .quote-actions {
          flex-direction: column;
        }

        .btn {
          width: 100%;
        }

        .mobile-sticky {
          position: fixed;
          left: 0.85rem;
          right: 0.85rem;
          bottom: 0.85rem;
          z-index: 60;
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 0.7rem;
          padding: 0.65rem;
          border-radius: 24px;
          background: rgba(7, 6, 4, 0.76);
          border: 1px solid rgba(255, 255, 255, 0.13);
          backdrop-filter: blur(22px);
          box-shadow: 0 24px 80px rgba(0, 0, 0, 0.42);
        }

        .mobile-sticky .btn {
          min-height: 44px;
          padding: 0.75rem 0.8rem;
          font-size: 0.86rem;
        }

        .footer {
          padding-bottom: 6.5rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          scroll-behavior: auto !important;
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
        }
      }
    </style>
  </head>

  <body>
    <div class="site">
      <nav class="nav">
        <a class="brand" href="/" aria-label="WhichwoodFitters home">
          <span class="brand-mark">W</span>
          <span class="brand-text">
            <strong>WhichwoodFitters</strong>
            <span>Custom Carpentry</span>
          </span>
        </a>

        <div class="nav-links" aria-label="Main navigation">
          <a href="#services">Services</a>
          <a href="#process">Process</a>
          <a href="#finishes">Finishes</a>
          <a href="#quote">Quote</a>
        </div>

        <div class="nav-actions">
          <button class="btn btn-ghost" type="button" data-copy-email>
            Copy Email
          </button>

          <a
            class="btn btn-primary"
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
          >
            WhatsApp
          </a>
        </div>
      </nav>

      <main>
        <section class="hero">
          <div class="hero-copy">
            <div class="status-pill">
              <span class="pulse"></span>
              Modern fitted storage for real homes
            </div>

            <h1>
              Custom cupboards that make your space feel
              <span class="gradient-text">expensive.</span>
            </h1>

            <p class="hero-lead">
              WhichwoodFitters designs and installs kitchens, built-in
              cupboards, wardrobes, TV units, vanities, and smart storage
              solutions made to fit your exact space.
            </p>

            <div class="hero-ctas">
              <a
                class="btn btn-primary"
                href={whatsappLink}
                target="_blank"
                rel="noopener noreferrer"
              >
                Get a WhatsApp Quote
              </a>

              <button class="btn btn-ghost" type="button" data-copy-email>
                Copy Email Address
              </button>

              <a class="btn btn-ghost" href={mailLink}>
                Open Email App
              </a>
            </div>

            <div class="contact-strip">
              <button class="contact-chip" type="button" data-copy-email>
                <span>
                  <small>Email</small>
                  <strong>{email}</strong>
                </span>
                <span class="arrow-icon">Copy</span>
              </button>

              <a
                class="contact-chip"
                href={whatsappLink}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span>
                  <small>WhatsApp</small>
                  <strong>{displayPhone}</strong>
                </span>
                <span class="arrow-icon">Open</span>
              </a>
            </div>
          </div>

          <div class="hero-panel-wrap">
            <div class="hero-panel">
              <div class="cabinet-visual">
                <div class="wood-slab slab-one"></div>
                <div class="wood-slab slab-two"></div>
                <div class="wood-slab slab-three"></div>

                <div class="floating-card">
                  <div class="floating-top">
                    <div>
                      <h2>Measured. Planned. Fitted clean.</h2>
                      <p>
                        Send your photos and rough measurements. We help turn
                        your idea into a practical, modern fitted solution.
                      </p>
                    </div>
                    <span class="mini-badge">Quote Ready</span>
                  </div>

                  <div class="mini-grid">
                    <div class="mini-stat">
                      <strong>01</strong>
                      <span>Photos</span>
                    </div>
                    <div class="mini-stat">
                      <strong>02</strong>
                      <span>Sizes</span>
                    </div>
                    <div class="mini-stat">
                      <strong>03</strong>
                      <span>Finish</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <div class="marquee" aria-hidden="true">
          <div class="marquee-track">
            <span>Custom Kitchens</span>
            <span>Built-In Cupboards</span>
            <span>Wardrobes</span>
            <span>TV Units</span>
            <span>Vanities</span>
            <span>Storage Solutions</span>
            <span>Custom Kitchens</span>
            <span>Built-In Cupboards</span>
            <span>Wardrobes</span>
            <span>TV Units</span>
            <span>Vanities</span>
            <span>Storage Solutions</span>
          </div>
        </div>

        <section class="section" id="services">
          <div class="section-head">
            <div>
              <span class="section-kicker">Services</span>
              <h2>Not flat-pack. Not guesswork. Built to fit.</h2>
            </div>

            <p>
              The value is in the fit: clean lines, proper measurements, strong
              materials, practical storage, and a finish that matches the room
              instead of fighting it.
            </p>
          </div>

          <div class="bento">
            {services.map((service, index) => (
              <article class="bento-card" style={`--delay: ${index * 90}ms`}>
                <div class="card-content">
                  <span class="tag">{service.tag}</span>
                  <h3>{service.title}</h3>
                  <p>{service.text}</p>
                </div>
                <div class="card-line"></div>
              </article>
            ))}
          </div>
        </section>

        <section class="section" id="process">
          <div class="section-head">
            <div>
              <span class="section-kicker">Process</span>
              <h2>A quote process that does not waste your time.</h2>
            </div>

            <p>
              For a faster estimate, send photos, rough sizes, and the type of
              build you want. Clear information gives you a cleaner quote and
              fewer expensive surprises.
            </p>
          </div>

          <div class="process-wrap">
            <div class="process-panel">
              <div class="process-art">
                <div class="process-art-card">
                  <strong>Best quote photos</strong>
                  <span>
                    Stand back, show the full wall, then send close-ups of
                    corners, plugs, pipes, floors, and ceiling height.
                  </span>
                </div>
              </div>
            </div>

            <div class="steps">
              {steps.map((step, index) => (
                <article class="step">
                  <div class="step-number">{String(index + 1).padStart(2, "0")}</div>
                  <div>
                    <h3>{step}</h3>
                    <p>
                      This keeps the job clear from the first message to the
                      final fitted result.
                    </p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="section" id="finishes">
          <div class="section-head">
            <div>
              <span class="section-kicker">Finishes</span>
              <h2>Modern finishes that make the build look premium.</h2>
            </div>

            <p>
              White, woodgrain, black details, soft-close hardware, and clean
              profiles are the easiest way to make cupboards feel current
              without overcomplicating the design.
            </p>
          </div>

          <div class="finish-lab">
            <div class="finish-card">
              <div class="sample-wall">
                <div class="sample sample-white" data-name="Iceberg / Nordic White"></div>
                <div class="sample sample-wood" data-name="Warm Woodgrain"></div>
                <div class="sample sample-black" data-name="Black Accent"></div>
                <div class="sample sample-stone" data-name="Stone / Quartz Look"></div>
              </div>
            </div>

            <div class="finish-card">
              <span class="section-kicker">Popular Choices</span>
              <h2>Clean, practical, and easy to live with.</h2>
              <p>
                A good finish must look sharp, clean easily, and still make
                sense for the budget. These are strong options for kitchens,
                wardrobes, TV units, and storage.
              </p>

              <div class="finish-list">
                {finishes.map((finish) => (
                  <span class="finish-pill">{finish}</span>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section class="quote-section" id="quote">
          <div class="quote-box">
            <div>
              <span class="section-kicker">Get a quote</span>
              <h2>Send your space. Get a clearer price.</h2>
              <p>
                WhatsApp your photos, rough measurements, finish idea, and what
                you want built. The better the details, the better the quote.
              </p>
            </div>

            <div class="quote-actions">
              <a
                class="btn btn-primary"
                href={whatsappLink}
                target="_blank"
                rel="noopener noreferrer"
              >
                WhatsApp {displayPhone}
              </a>

              <button class="btn btn-ghost" type="button" data-copy-email>
                Copy {email}
              </button>

              <a class="btn btn-ghost" href={mailLink}>
                Open Email App
              </a>
            </div>
          </div>
        </section>
      </main>

      <footer class="footer">
        <span>© 2026 WhichwoodFitters. All rights reserved.</span>
        <span>Custom kitchens • cupboards • wardrobes • TV units • vanities</span>
      </footer>

      <div class="mobile-sticky" aria-label="Quick contact buttons">
        <button class="btn btn-ghost" type="button" data-copy-email>
          Email
        </button>

        <a
          class="btn btn-primary"
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
        >
          WhatsApp
        </a>
      </div>

      <div class="toast" id="emailToast" role="status" aria-live="polite">
        Email copied: {email}
      </div>
    </div>

    <script define:vars={{ email, mailLink }}>
      const copyButtons = document.querySelectorAll("[data-copy-email]");
      const toast = document.getElementById("emailToast");

      function showToast(message) {
        if (!toast) return;

        toast.textContent = message;
        toast.classList.add("show");

        window.setTimeout(() => {
          toast.classList.remove("show");
        }, 2400);
      }

      function fallbackCopy(text) {
        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        textarea.style.top = "0";

        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();

        const successful = document.execCommand("copy");
        document.body.removeChild(textarea);

        return successful;
      }

      async function copyEmail() {
        try {
          if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText(email);
          } else {
            const copied = fallbackCopy(email);

            if (!copied) {
              throw new Error("Fallback copy failed.");
            }
          }

          showToast(`Email copied: ${email}`);
        } catch {
          showToast(`Email: ${email}`);
          window.setTimeout(() => {
            window.location.href = mailLink;
          }, 900);
        }
      }

      copyButtons.forEach((button) => {
        button.addEventListener("click", copyEmail);
      });
    </script>
  </body>
</html>
