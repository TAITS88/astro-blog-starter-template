<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Gallery | WhichwoodFitters</title>

    <meta
      name="description"
      content="View WhichwoodFitters gallery for custom kitchens, built-in cupboards, wardrobes, TV units, vanities and fitted storage."
    />

    <style>
      :root {
        --paper: #f4efe5;
        --paper-soft: #ebe1d1;
        --ink: #201a13;
        --muted: #74695c;
        --wood: #9a6535;
        --wood-dark: #4b2b16;
        --line: rgba(32, 26, 19, 0.16);
        --line-dark: rgba(32, 26, 19, 0.32);
        --shadow: 0 36px 110px rgba(58, 38, 18, 0.16);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--ink);
        background:
          radial-gradient(circle at 12% 5%, rgba(154, 101, 53, 0.15), transparent 30rem),
          radial-gradient(circle at 88% 14%, rgba(98, 106, 79, 0.12), transparent 28rem),
          linear-gradient(135deg, var(--paper), var(--paper-soft));
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.13;
        background-image:
          linear-gradient(rgba(32, 26, 19, 0.14) 1px, transparent 1px),
          linear-gradient(90deg, rgba(32, 26, 19, 0.14) 1px, transparent 1px);
        background-size: 86px 86px;
        mask-image: linear-gradient(to bottom, black, transparent 82%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      h1,
      h2,
      h3 {
        font-family: Georgia, "Times New Roman", serif;
        font-weight: 500;
      }

      .site {
        position: relative;
        z-index: 1;
      }

      .nav {
        position: fixed;
        inset: 0 0 auto;
        z-index: 50;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
        padding: 1.1rem clamp(1rem, 4vw, 4.8rem);
        background: rgba(244, 239, 229, 0.78);
        border-bottom: 1px solid rgba(32, 26, 19, 0.08);
        backdrop-filter: blur(22px);
      }

      .back-link,
      .nav-email {
        border: 0;
        padding: 0;
        width: fit-content;
        color: var(--ink);
        background: transparent;
        cursor: pointer;
        font-weight: 850;
      }

      .brand {
        justify-self: center;
        display: grid;
        justify-items: center;
        line-height: 1;
      }

      .brand strong {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.55rem, 3vw, 2.3rem);
        letter-spacing: -0.085em;
        font-weight: 500;
      }

      .brand span {
        margin-top: 0.28rem;
        color: var(--muted);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-weight: 850;
      }

      .nav-email {
        justify-self: end;
      }

      .hero {
        min-height: 78vh;
        display: grid;
        align-items: end;
        padding: 8rem clamp(1rem, 4vw, 4.8rem) 3rem;
      }

      .page-label {
        display: inline-flex;
        width: fit-content;
        margin-bottom: 1.4rem;
        padding: 0.54rem 0.85rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: var(--wood-dark);
        background: rgba(255, 250, 241, 0.42);
        font-size: 0.8rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.14em;
      }

      .hero h1 {
        margin: 0;
        max-width: 1180px;
        font-size: clamp(4.5rem, 13vw, 12.5rem);
        line-height: 0.76;
        letter-spacing: -0.105em;
      }

      .hero h1 span {
        display: block;
        color: var(--wood);
      }

      .hero-text {
        max-width: 760px;
        margin: 1.6rem 0 0;
        color: var(--muted);
        font-size: clamp(1.05rem, 1.55vw, 1.22rem);
        line-height: 1.82;
      }

      .hero-actions,
      .option-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 2rem;
      }

      .btn,
      .option-link {
        min-height: 48px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0.9rem 1.18rem;
        border: 1px solid var(--line-dark);
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: 900;
        transition:
          transform 0.2s ease,
          background 0.2s ease,
          border-color 0.2s ease;
      }

      .btn:hover,
      .option-link:hover {
        transform: translateY(-2px);
      }

      .btn-dark,
      .option-link {
        color: var(--paper);
        background: var(--ink);
        border-color: var(--ink);
      }

      .btn-light {
        color: var(--ink);
        background: rgba(255, 250, 241, 0.5);
      }

      .btn-outline-light {
        color: var(--paper);
        background: transparent;
        border-color: rgba(244, 239, 229, 0.34);
      }

      .section {
        padding: clamp(4.8rem, 8vw, 8.5rem) clamp(1rem, 4vw, 4.8rem);
      }

      .section-title {
        display: grid;
        grid-template-columns: 120px 1fr;
        gap: 1rem;
        align-items: start;
        margin-bottom: 2rem;
      }

      .section-title small {
        color: var(--muted);
        font-weight: 950;
        letter-spacing: 0.13em;
        text-transform: uppercase;
      }

      .section-title h2 {
        margin: 0;
        max-width: 1120px;
        font-size: clamp(3.2rem, 8vw, 8.3rem);
        line-height: 0.82;
        letter-spacing: -0.1em;
      }

      .option-grid {
        margin-top: 0;
      }

      .gallery-section {
        scroll-margin-top: 110px;
        padding: clamp(4.8rem, 8vw, 8.5rem) clamp(1rem, 4vw, 4.8rem);
        border-top: 1px solid var(--line);
      }

      .gallery-heading {
        display: grid;
        grid-template-columns: 0.8fr 1.2fr;
        gap: clamp(1rem, 4vw, 4rem);
        align-items: end;
        margin-bottom: 2rem;
      }

      .gallery-heading h2 {
        margin: 0;
        font-size: clamp(3.4rem, 8vw, 8.5rem);
        line-height: 0.8;
        letter-spacing: -0.1em;
      }

      .gallery-heading p {
        margin: 0;
        max-width: 700px;
        color: var(--muted);
        font-size: 1.08rem;
        line-height: 1.85;
      }

      .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border-top: 1px solid var(--line);
        border-left: 1px solid var(--line);
      }

      .gallery-card {
        min-height: 610px;
        display: grid;
        align-content: space-between;
        background: rgba(255, 250, 241, 0.22);
        border-right: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .gallery-image {
        position: relative;
        min-height: 360px;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        overflow: hidden;
      }

      .gallery-image::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(0deg, rgba(32, 26, 19, 0.45), transparent 58%),
          radial-gradient(circle at 30% 18%, rgba(255, 255, 255, 0.24), transparent 19rem);
      }

      .gallery-badge {
        position: absolute;
        left: 1rem;
        bottom: 1rem;
        z-index: 2;
        padding: 0.62rem 0.85rem;
        border-radius: 999px;
        background: rgba(255, 250, 241, 0.86);
        color: var(--ink);
        font-weight: 950;
        backdrop-filter: blur(14px);
      }

      .gallery-content {
        padding: 1.45rem;
      }

      .gallery-content h3 {
        margin: 0;
        font-size: clamp(2rem, 3.2vw, 3.3rem);
        line-height: 0.92;
        letter-spacing: -0.08em;
      }

      .gallery-content p {
        margin: 1rem 0 0;
        color: var(--muted);
        line-height: 1.72;
      }

      .card-link {
        display: inline-flex;
        margin-top: 1.2rem;
        color: var(--wood-dark);
        font-weight: 950;
      }

      .quote-section {
        margin: 0 clamp(1rem, 4vw, 4.8rem) clamp(4.8rem, 8vw, 8rem);
        display: grid;
        grid-template-columns: 1fr 0.82fr;
        min-height: 560px;
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .quote-copy {
        display: grid;
        align-content: center;
        padding: clamp(2rem, 5vw, 5rem) 0;
      }

      .quote-copy h2 {
        margin: 0;
        max-width: 840px;
        font-size: clamp(3.6rem, 9vw, 9rem);
        line-height: 0.78;
        letter-spacing: -0.105em;
      }

      .quote-copy p {
        max-width: 660px;
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.9;
      }

      .contact-card {
        margin: clamp(2rem, 4vw, 4rem) 0 clamp(2rem, 4vw, 4rem) clamp(1rem, 4vw, 4rem);
        padding: 1.4rem;
        display: grid;
        align-content: space-between;
        background: var(--ink);
        color: var(--paper);
        border-radius: 48px;
        box-shadow: var(--shadow);
      }

      .contact-card h3 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 4rem);
        line-height: 0.88;
        letter-spacing: -0.08em;
      }

      .contact-card p {
        color: rgba(244, 239, 229, 0.68);
        line-height: 1.75;
      }

      .contact-actions {
        display: grid;
        gap: 0.8rem;
      }

      .contact-card .btn-light {
        background: var(--paper);
        color: var(--ink);
        border-color: var(--paper);
      }

      .footer {
        display: grid;
        grid-template-columns: 1.2fr 1fr 1fr;
        gap: 2rem;
        padding: clamp(2rem, 5vw, 4.8rem);
        border-top: 1px solid var(--line);
        color: var(--muted);
      }

      .footer strong {
        display: block;
        color: var(--ink);
        margin-bottom: 0.7rem;
      }

      .footer a,
      .footer button {
        display: block;
        width: fit-content;
        border: 0;
        padding: 0;
        margin-top: 0.35rem;
        background: transparent;
        color: var(--muted);
        cursor: pointer;
      }

      .toast {
        position: fixed;
        left: 50%;
        bottom: 2rem;
        z-index: 120;
        transform: translateX(-50%) translateY(18px);
        opacity: 0;
        pointer-events: none;
        max-width: calc(100vw - 2rem);
        padding: 0.9rem 1.1rem;
        border-radius: 999px;
        background: var(--ink);
        color: var(--paper);
        font-weight: 950;
        box-shadow: var(--shadow);
        transition: 0.25s ease;
      }

      .toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      .mobile-sticky {
        display: none;
      }

      @media (max-width: 1100px) {
        .gallery-heading,
        .gallery-grid,
        .quote-section {
          grid-template-columns: 1fr;
        }

        .contact-card {
          margin-left: 0;
        }

        .footer {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 720px) {
        .nav {
          grid-template-columns: auto 1fr auto;
          padding: 0.85rem 1rem;
        }

        .brand {
          justify-self: start;
        }

        .brand strong {
          font-size: 1.3rem;
        }

        .brand span,
        .nav-email {
          display: none;
        }

        .hero {
          min-height: auto;
          padding: 6.4rem 1rem 2rem;
        }

        .hero h1 {
          font-size: clamp(4.1rem, 20vw, 6.5rem);
        }

        .hero-actions,
        .option-grid {
          display: grid;
        }

        .btn,
        .option-link {
          width: 100%;
        }

        .section,
        .gallery-section {
          padding: 4rem 1rem;
        }

        .section-title {
          grid-template-columns: 1fr;
        }

        .section-title h2,
        .gallery-heading h2,
        .quote-copy h2 {
          font-size: clamp(3.4rem, 17vw, 5.8rem);
        }

        .gallery-card {
          min-height: auto;
        }

        .gallery-image {
          min-height: 280px;
        }

        .quote-section {
          margin-inline: 1rem;
        }

        .mobile-sticky {
          position: fixed;
          left: 0.85rem;
          right: 0.85rem;
          bottom: 0.85rem;
          z-index: 60;
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 0.65rem;
          padding: 0.6rem;
          border-radius: 22px;
          background: rgba(244, 239, 229, 0.86);
          backdrop-filter: blur(18px);
          border: 1px solid var(--line);
          box-shadow: var(--shadow);
        }

        .mobile-sticky .btn {
          min-height: 44px;
          padding: 0.75rem 0.8rem;
          font-size: 0.84rem;
        }

        .footer {
          padding-bottom: 6.5rem;
        }
      }
    </style>
  </head>

  <body>
    <div class="site">
      <nav class="nav">
        <a class="back-link" href="/">
          ← Home
        </a>

        <a class="brand" href="/" aria-label="WhichwoodFitters home">
          <strong>Whichwood</strong>
          <span>Gallery</span>
        </a>

        <button class="nav-email" type="button" data-copy-email>
          {email}
        </button>
      </nav>

      <main>
        <section class="hero">
          <div>
            <span class="page-label">Project Gallery</span>

            <h1>
              Choose what
              <span>you want to see.</span>
            </h1>

            <p class="hero-text">
              Select a gallery option below. Each option jumps to that project
              type, so visitors can quickly view kitchens, cupboards, TV units,
              vanities, storage ideas and custom fitted carpentry.
            </p>

            <div class="hero-actions">
              <a class="btn btn-dark" href={whatsappLink} target="_blank" rel="noopener noreferrer">
                WhatsApp for quote
              </a>

              <button class="btn btn-light" type="button" data-copy-email>
                Copy email
              </button>
            </div>
          </div>
        </section>

        <section class="section">
          <div class="section-title">
            <small>Options</small>
            <h2>What do you want to see?</h2>
          </div>

          <div class="option-grid">
            {sections.map((section) => (
              <a class="option-link" href={`#${section.id}`}>
                {section.label}
              </a>
            ))}
          </div>
        </section>

        {sections.map((section) => (
          <section class="gallery-section" id={section.id}>
            <div class="gallery-heading">
              <h2>{section.title}</h2>
              <p>{section.description}</p>
            </div>

            <div class="gallery-grid">
              {section.items.map((item) => (
                <article class="gallery-card">
                  <div
                    class="gallery-image"
                    style={`background-image: url('${item.image}');`}
                  >
                    <span class="gallery-badge">{section.label}</span>
                  </div>

                  <div class="gallery-content">
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                    <a class="card-link" href={whatsappLink} target="_blank" rel="noopener noreferrer">
                      Ask about this →
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}

        <section class="quote-section">
          <div class="quote-copy">
            <span class="page-label">Seen something you like?</span>

            <h2>Send your idea.</h2>

            <p>
              Send a screenshot from the gallery, your room photos, rough
              measurements and your location. WhatsApp is the fastest way to
              start the quote.
            </p>
          </div>

          <div class="contact-card">
            <div>
              <h3>WhichwoodFitters</h3>
              <p>
                Custom kitchens, built-in cupboards, wardrobes, TV units,
                vanities and fitted storage.
              </p>
            </div>

            <div class="contact-actions">
              <a class="btn btn-light" href={whatsappLink} target="_blank" rel="noopener noreferrer">
                WhatsApp {displayPhone}
              </a>

              <button class="btn btn-outline-light" type="button" data-copy-email>
                Copy {email}
              </button>

              <a class="btn btn-outline-light" href={mailLink}>
                Open email app
              </a>
            </div>
          </div>
        </section>
      </main>

      <footer class="footer">
        <div>
          <strong>WhichwoodFitters</strong>
          <span>Custom carpentry and fitted storage.</span>
        </div>

        <div>
          <strong>Contact</strong>
          <a href={whatsappLink} target="_blank" rel="noopener noreferrer">
            WhatsApp {displayPhone}
          </a>
          <button type="button" data-copy-email>{email}</button>
        </div>

        <div>
          <strong>Gallery Options</strong>
          {sections.map((section) => (
            <a href={`#${section.id}`}>{section.label}</a>
          ))}
        </div>
      </footer>

      <div class="mobile-sticky">
        <button class="btn btn-light" type="button" data-copy-email>
          Email
        </button>

        <a class="btn btn-dark" href={whatsappLink} target="_blank" rel="noopener noreferrer">
          WhatsApp
        </a>
      </div>

      <div class="toast" id="emailToast" role="status" aria-live="polite">
        Email copied: {email}
      </div>
    </div>

    <script define:vars={{ email, mailLink }}>
      const copyButtons = document.querySelectorAll("[data-copy-email]");
      const toast = document.getElementById("emailToast");

      function showToast(message) {
        if (!toast) return;

        toast.textContent = message;
        toast.classList.add("show");

        window.setTimeout(() => {
          toast.classList.remove("show");
        }, 2400);
      }

      function fallbackCopy(text) {
        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        textarea.style.top = "0";

        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();

        const successful = document.execCommand("copy");
        document.body.removeChild(textarea);

        return successful;
      }

      async function copyEmail() {
        try {
          if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText(email);
          } else {
            const copied = fallbackCopy(email);

            if (!copied) {
              throw new Error("Fallback copy failed.");
            }
          }

          showToast(`Email copied: ${email}`);
        } catch {
          showToast(`Email: ${email}`);

          window.setTimeout(() => {
            window.location.href = mailLink;
          }, 900);
        }
      }

      copyButtons.forEach((button) => {
        button.addEventListener("click", copyEmail);
      });
    </script>
  </body>
</html>
